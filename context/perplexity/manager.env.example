NODE_ENV=${NODE_ENV}
PORT=${PORT}

# Database
DATABASE_URL=${DATABASE_URL}

# Redis
REDIS_URL=${REDIS_URL}

# API Key (auto-generated on first run if empty)
HEADY_API_KEY=${HEADY_API_KEY}

# CORS origins (comma-separated)
ALLOWED_ORIGINS=${ALLOWED_ORIGINS}

# Resource management
RESOURCE_POLL_INTERVAL_MS=${RESOURCE_POLL_INTERVAL_MS}
RESOURCE_LOG_FILE=${RESOURCE_LOG_FILE}

# Task scheduler
SCHEDULER_BATCH_CONCURRENCY=${SCHEDULER_BATCH_CONCURRENCY}
SCHEDULER_TRAINING_CONCURRENCY=${SCHEDULER_TRAINING_CONCURRENCY}
SCHEDULER_INTERACTIVE_CONCURRENCY=${SCHEDULER_INTERACTIVE_CONCURRENCY}

# MCP
MCP_SERVER_URL=${MCP_SERVER_URL}

# Facebook / Meta (Heady-AI Meta App)
FACEBOOK_APP_ID=${FB_APP_ID}
FACEBOOK_APP_SECRET=${FB_APP_SECRET}
FACEBOOK_PAGE_ACCESS_TOKEN=${FB_PAGE_TOKEN}
