// Heady User & Onboarding Schema
// Database: PostgreSQL with pgvector extension

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id                  String    @id @default(cuid())
  firebaseUid         String    @unique @map("firebase_uid")
  username            String?   @unique
  headyEmail          String?   @unique @map("heady_email")
  displayName         String?   @map("display_name")
  email               String?   // OAuth provider email
  photoURL            String?   @map("photo_url")
  provider            String    @default("unknown")
  
  // Onboarding state
  onboardingComplete  Boolean   @default(false) @map("onboarding_complete")
  lastOnboardingStage String?   @map("last_onboarding_stage")
  onboardingStartedAt DateTime? @map("onboarding_started_at")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  
  // Email config
  emailMode           String?   @map("email_mode")  // secure-client | forward-provider | forward-custom
  emailForwardTo      String?   @map("email_forward_to")
  
  // Runtime permissions
  runtimeMode         String    @default("cloud-only") @map("runtime_mode") // cloud-only | hybrid
  
  // Buddy config (stored as JSON)
  buddyName           String?   @map("buddy_name")
  buddyTheme          String    @default("sacred-geometry") @map("buddy_theme")
  buddyContexts       String[]  @default(["default"]) @map("buddy_contexts")
  voiceEnabled        Boolean   @default(false) @map("voice_enabled")
  
  // API access
  apiKeys             ApiKey[]
  
  // Activity
  onboardingLogs      OnboardingLog[]
  sessions            Session[]
  
  // Timestamps
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  lastLoginAt         DateTime? @map("last_login_at")

  @@map("users")
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  key       String   @unique
  name      String   @default("Default")
  scope     String   @default("pilot") // pilot | full | admin
  active    Boolean  @default(true)
  lastUsed  DateTime? @map("last_used")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime? @map("expires_at")

  // Usage tracking
  usageLogs ApiKeyUsage[]

  @@map("api_keys")
}

model ApiKeyUsage {
  id        String   @id @default(cuid())
  apiKeyId  String   @map("api_key_id")
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id])
  endpoint  String
  method    String
  status    Int
  latencyMs Int      @map("latency_ms")
  timestamp DateTime @default(now())

  @@index([apiKeyId, timestamp])
  @@map("api_key_usage")
}

model OnboardingLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  stage       String
  action      String   // started | completed | skipped | error
  data        Json?
  durationMs  Int?     @map("duration_ms")
  timestamp   DateTime @default(now())

  @@index([userId, timestamp])
  @@map("onboarding_logs")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id])
  token        String   @unique
  provider     String
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")
  lastActiveAt DateTime @default(now()) @map("last_active_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// Vector memory for user embeddings (3D projection of 384-dim)
model UserVector {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  key         String   // semantic key
  embedding   Unsupported("vector(384)")
  x           Float    @default(0) // 3D projected coordinates
  y           Float    @default(0)
  z           Float    @default(0)
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, key])
  @@map("user_vectors")
}
