{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://headysystems.com/schemas/headybee-template.schema.json",
  "title": "HeadyBee Template",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "domain",
    "intent",
    "priority",
    "skills",
    "workflows",
    "nodes",
    "headyswarmTasks",
    "triggers",
    "runtime",
    "projection",
    "observability",
    "autonomousOptimization",
    "outputs"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]+$"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "intent": {
      "type": "string"
    },
    "priority": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "category": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "workflows": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "headyswarmTasks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "services": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "configs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "receipts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "required": [
        "executionMode",
        "queueClass",
        "timeoutMs",
        "retryBudget",
        "factoryTemplate"
      ],
      "properties": {
        "executionMode": {
          "type": "string",
          "enum": [
            "persistent",
            "ephemeral",
            "hybrid"
          ]
        },
        "queueClass": {
          "type": "string"
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "retryBudget": {
          "type": "integer",
          "minimum": 0
        },
        "factoryTemplate": {
          "type": "string"
        },
        "minConcurrency": {
          "type": "integer",
          "minimum": 1
        },
        "maxConcurrency": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "projection": {
      "type": "object",
      "required": [
        "enabled",
        "surface",
        "manifestTargets"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "surface": {
          "type": "string"
        },
        "manifestTargets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "freshnessSlaMs": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "observability": {
      "type": "object",
      "required": [
        "healthEndpoint",
        "metrics",
        "receipts"
      ],
      "properties": {
        "healthEndpoint": {
          "type": "string"
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "receipts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "alerts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "autonomousOptimization": {
      "type": "object",
      "required": [
        "channels",
        "scoringDimensions"
      ],
      "properties": {
        "channels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "scoringDimensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "outcomeStore": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "outputs": {
      "type": "object",
      "required": [
        "artifacts",
        "events"
      ],
      "properties": {
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "events": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
