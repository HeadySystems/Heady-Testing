{
    "name": "@heady-ai/template-swarm-bee",
    "version": "1.0.0",
    "description": "Heady™ Ephemeral Swarm Bee Agent Template",
    "private": true,
    "scripts": {
        "start": "node src/index.js",
        "dev": "node --watch src/index.js",
        "docker:build": "docker build -t heady-bee .",
        "docker:run": "docker run --rm heady-bee"
    },
    "dependencies": {
        "@google-cloud/pubsub": "^4.3.0",
        "pg": "^8.12.0",
        "dotenv": "^16.4.0"
    },
    "heady": {
        "template": "swarm-bee",
        "ephemeral": true,
        "selfDestruct": true,
        "lifecycle": [
            "init",
            "execute",
            "report",
            "destruct"
        ]
    }
}