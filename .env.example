# Heady Systems Environment Configuration
# Copy to .env and fill in values — never commit .env to git

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3300
NODE_ENV=development
HEADY_VERSION=3.0.0

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://heady:heady_secret@api.headysystems.com:5432/heady

# ── Authentication ────────────────────────────────────────────────────────────
HEADY_API_KEY=
ADMIN_TOKEN=

# ── AI APIs ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
HF_TOKEN=
GOOGLE_AI_API_KEY=

# ── Cloud Connection Mode ─────────────────────────────────────────────────────
# HEADY_TARGET options: CloudOnly | LocalDev | Hybrid
HEADY_TARGET=Hybrid
HEADY_CLOUD_MODE=true
HEADY_LOCAL_SERVICES_ENABLED=true

# Primary endpoints
HEADY_ACTIVE_ENDPOINT=https://cloud.headysystems.com
CLOUD_HEADYME_URL=https://heady-manager-headyme.headysystems.com
CLOUD_HEADYSYSTEMS_URL=https://heady-manager-headysystems.headysystems.com
CLOUD_HEADYCONNECTION_URL=https://heady-manager-headyconnection.headysystems.com

# ── Colab Pro+ Runtimes ───────────────────────────────────────────────────────
# COLAB_PRO_TOKEN: your Google account OAuth token for runtime API access
COLAB_PRO_TOKEN=
COLAB_ALPHA_URL=
COLAB_BETA_URL=
COLAB_GAMMA_URL=

# ── GitHub Integration ────────────────────────────────────────────────────────
# GITHUB_TOKEN needs 'gist' scope for GistStore checkpointing
GITHUB_TOKEN=
GITHUB_ACTOR=heady-systems

# ── Cloudflare ────────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_WORKER_NAME=heady-edge
HEADY_TUNNEL_ID_HEADYME=
HEADY_TUNNEL_ID_HEADYSYSTEMS=
HEADY_TUNNEL_ID_HEADYCONNECTION=
HEADY_TUNNEL_ID_HEADYMCP=
HEADY_TUNNEL_ID_HEADYIO=
HEADY_TUNNEL_ID_HEADYBUDDY=
HEADY_TUNNEL_ID_HEADYBOT=
HEADY_TUNNEL_ID_HEADYAI=
HEADY_TUNNEL_ID_HEADYAPI=

# ── Google Cloud Platform ─────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCP_SA_KEY=
VPC_CONNECTOR=projects/your-gcp-project-id/locations/us-central1/connectors/heady-vpc-connector
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_ENDPOINT=

# ── Vector Memory ─────────────────────────────────────────────────────────────
VECTOR_DIMENSIONS=384
EMBEDDING_PROVIDER=local
EMBEDDING_LOCAL_URL=http://127.0.0.1:11434/api/embeddings
EMBEDDING_LOCAL_MODEL=nomic-embed-text
PINECONE_API_KEY=
PINECONE_INDEX=heady-vectors

# ── AI Node Toggles ───────────────────────────────────────────────────────────
ENABLE_CODEMAP=true
ENABLE_JULES=true
ENABLE_PERPLEXITY=false
ENABLE_OBSERVER=true
ENABLE_SYNC_SERVICE=false
ENABLE_PQC=false
ENABLE_BUILDER=true
ENABLE_ATLAS=true

# ── Python Worker ─────────────────────────────────────────────────────────────
PYTHON_WORKER_PATH=backend/python_worker
HEADY_PYTHON_BIN=python

# ── Phi-Resonance Tuning ──────────────────────────────────────────────────────
PHI_PRECISION=15
HEARTBEAT_MULTIPLIER=7
RATE_LIMIT_BASE_RPM=120

# ── Feature Flags ─────────────────────────────────────────────────────────────
CSL_GATES_ENABLED=true
AUTO_SUCCESS_ENABLED=false
SOCRATIC_LOOP_ENABLED=true
SELF_HEALING=true
MCP_SERVER=true
VOICE_RELAY=false
