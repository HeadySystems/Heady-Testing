# =============================================================================
# Heady™ Latent OS — Environment Configuration
# Version: 4.0.0 | Updated: 2026-03-08
# Copy to .env and fill in all values before running
# =============================================================================

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
HEADY_ENV=production
LOG_LEVEL=info
PORT=3301

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@postgres:5432/heady
REDIS_URL=redis://redis:6379

# ── Cloudflare ───────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCESS_AUDIENCE=
CLOUDFLARE_VECTORIZE_INDEX=heady-memory-edge
CF_ZONE_HEADYME=
CF_ZONE_HEADYSYSTEMS=
CF_ZONE_HEADYCONNECTION_ORG=
CF_ZONE_HEADYCONNECTION_COM=
CF_ZONE_HEADYBUDDY=
CF_ZONE_HEADYMCP=
CF_ZONE_HEADYIO=
CF_ZONE_HEADYBOT=
CF_ZONE_HEADYAPI=
CF_ZONE_HEADY_AI=
CF_ZONE_HEADYOS=
CF_ZONE_HEADYCLOUD=
CF_ZONE_HEADYWEB=
CF_ZONE_HEADYFINANCE=
CF_ZONE_HEADYMUSIC=
CF_ZONE_HEADYSTORE=
CF_ZONE_HEADYEX=

# ── Google Cloud ──────────────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_EMAIL=
DEFAULT_REGION=us-central1
CLOUD_RUN_SERVICE=heady-manager
CLOUD_RUN_ORIGIN=https://heady-production-uc.a.run.app

# ── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=
HF_TOKEN=

# ── Heady Platform ───────────────────────────────────────────────────────────
HEADY_API_KEY=
HEADY_MANAGER_URL=http://localhost:3301
HEADY_BRAIN_URL=http://localhost:3301

# ── Security & Auth ───────────────────────────────────────────────────────────
JWT_ISSUER=heady
JWT_AUDIENCE=heady-services
JWT_SECRET=
ED25519_PUBLIC_KEY=
ED25519_PRIVATE_KEY=
SESSION_SECRET=

# ── MCP ───────────────────────────────────────────────────────────────────────
MCP_SESSION_DO_NAME=HeadyMcpSession
MCP_MAX_TOOLS=42

# ── Observability ─────────────────────────────────────────────────────────────
OBSERVABILITY_EXPORT_URL=http://otel-collector:4316/v1/traces
OTEL_SERVICE_NAME=heady-manager
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4316

# ── Services ──────────────────────────────────────────────────────────────────
HEADY_EMBED_URL=http://localhost:3101
HEADY_INFER_URL=http://localhost:3102
HEADY_VECTOR_URL=http://localhost:3103
HEADY_CHAIN_URL=http://localhost:3104
HEADY_CACHE_URL=http://localhost:3105
HEADY_GUARD_URL=http://localhost:3106
HEADY_EVAL_URL=http://localhost:3107

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_VECTOR_MEMORY=true
ENABLE_SWARM=true
ENABLE_MCP=true
ENABLE_VOICE=true
ENABLE_PQC=false
MAINTENANCE_MODE=false

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=100
