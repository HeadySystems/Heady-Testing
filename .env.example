# Heady™ Latent OS — Environment Configuration v4.0.0
# Copy to .env and fill in values — never commit .env to git

# ── Runtime ─────────────────────────────────────────────
NODE_ENV=production
HEADY_ENV=production
LOG_LEVEL=info
PORT=3301
HEADY_VERSION=3.1.0

# ── Database (Neon Postgres) ────────────────────────────
DATABASE_URL=
DB_HOST=
DB_SSL=true

# ── Cache (Upstash Redis — rediss:// required) ─────────
REDIS_URL=

# ── Auth (Firebase) ────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
JWT_SECRET=
HEADY_API_KEY=
ADMIN_TOKEN=

# ── AI Providers ───────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=
HF_TOKEN=

# ── GCloud + Vertex AI ─────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_AI_LOCATION=

# ── Azure ──────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Cloudflare ─────────────────────────────────────────
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_ZONE_ID=

# ── GitHub ─────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# ── Sentry ─────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── NotebookLM ─────────────────────────────────────────────
NOTEBOOKLM_API_KEY=
NOTEBOOKLM_PROJECT_ID=

# ── Discord ────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# ── Heady Endpoints ───────────────────────────────────
HEADY_MANAGER_URL=https://headyapi.com
HEADY_BRAIN_URL=https://headyapi.com
HEADY_EDGE_PROXY_URL=https://heady-edge-proxy.emailheadyconnection.workers.dev
HEADY_CLOUDRUN_URL=https://heady-production-uc.a.run.app
HEADY_CONDUCTOR_URL=https://headyapi.com
QDRANT_URL=https://qdrant.headysystems.com

# ── Colab Pro+ Runtimes ───────────────────────────────
COLAB_PRO_TOKEN=
COLAB_ALPHA_URL=
COLAB_BETA_URL=
COLAB_GAMMA_URL=

# ── AI Node Toggles ───────────────────────────────────
ENABLE_CODEMAP=false
ENABLE_JULES=false
ENABLE_PERPLEXITY=false
ENABLE_OBSERVER=false
ENABLE_SYNC_SERVICE=false
ENABLE_PQC=false
ENABLE_BUILDER=false
ENABLE_ATLAS=false

# ── Feature Flags ──────────────────────────────────────
HEADY_CLOUD_MODE=true
HEADY_LOCAL_SERVICES_ENABLED=false
