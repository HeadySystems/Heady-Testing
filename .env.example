HEADY_VERSION=3.0.0

# Cloud connection settings
HEADY_CLOUD_MODE=true
HEADY_LOCAL_SERVICES_ENABLED=false
HEADY_ACTIVE_ENDPOINT=https://cloud.headysystems.com

