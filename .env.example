<<<<<<< HEAD
# Signs all inter-agent JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=

# Signs inter-agent message envelopes (HMAC-SHA256). Generate with: openssl rand -hex 32
HMAC_SECRET=

# Redis connection string for the message bus. Format: redis://host:port/db
# For Redis Cluster: redis://host1:port1,host2:port2,host3:port3
REDIS_URL=

# CORS whitelist — comma-separated, explicit origins only. NO wildcards ('*').
# Example: https://app.headysystems.com,https://admin.headysystems.com
ALLOWED_ORIGINS=

# ----- RUNTIME IDENTITY -----

# Which Colab runtime this instance is. One of: cortex, synapse, reflex
# Cortex = A100 80GB (primary inference)
# Synapse = A100 40GB (vector ops, embeddings)
# Reflex = T4/L4 (lightweight agents, monitoring)
HEADY_RUNTIME=cortex

# Port for the local HTTP server (inter-runtime communication)
PORT=8001
