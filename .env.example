# =============================================================================
# Heady™ Latent OS — Environment Configuration
# Version: 4.0.0 | Updated: 2026-03-08
# Copy to .env and fill in all values before running
# =============================================================================

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
HEADY_ENV=production
LOG_LEVEL=info
PORT=3301

# Database
DATABASE_URL=postgresql://heady:YOUR_PASSWORD@db.headysystems.com:5432/heady

# Authentication
# Heady Cloud API Key
# Get yours from https://cloud.headysystems.com/api-keys
HEADY_API_KEY=
ADMIN_TOKEN=

# Cloud Targets
HEADY_TARGET=LocalDev
HEADY_VERSION=3.0.0

# Cloud connection settings
HEADY_CLOUD_MODE=false
HEADY_LOCAL_SERVICES_ENABLED=true
HEADY_ACTIVE_ENDPOINT=https://cloud.headysystems.com

# Disable local service toggles
HEADY_POSTGRES_ENABLED=true
HEADY_REDIS_ENABLED=true
HEADY_MANAGER_LOCAL=true

# AI Nodes
ENABLE_CODEMAP=true
JULES_ENABLED=true
OBSERVER_ENABLED=true
BUILDER_ENABLED=true
ATLAS_ENABLED=true
ENABLE_PERPLEXITY=false
ENABLE_SYNC_SERVICE=false
ENABLE_PQC=false

# Hugging Face
HF_TOKEN=

# ── Heady Platform ───────────────────────────────────────────────────────────
HEADY_API_KEY=
HEADY_MANAGER_URL=http://localhost:3301
HEADY_BRAIN_URL=http://localhost:3301

# Cloud Endpoints (for hybrid mode)
HEADY_ENDPOINT=https://api.headysystems.com
MANAGER_ENDPOINT=https://manager.headysystems.com
REGISTRY_ENDPOINT=https://registry.headysystems.com
CLOUD_HEADYME_URL=https://heady-manager-headyme.headysystems.com
CLOUD_HEADYSYSTEMS_URL=https://heady-manager-headysystems.headysystems.com
CLOUD_HEADYCONNECTION_URL=https://heady-manager-headyconnection.headysystems.com