# ══════════════════════════════════════════════════════════════════
# HEADY™ Environment Template — Copy to .env and fill in values
# NEVER commit the real .env file. This template is safe.
# ══════════════════════════════════════════════════════════════════

# ─── HEADY INTERNAL AUTH ─────────────────────────────────────────
HEADY_API_KEY=
ADMIN_TOKEN=

# ─── NEON DATABASE (Scale Plan) ──────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
NEON_API_KEY=
NEON_PROJECT_ID=

# ─── UPSTASH REDIS ──────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_REDIS_REST_TOKEN_RO=
UPSTASH_REDIS_PASSWORD=
UPSTASH_REDIS_ENDPOINT=
UPSTASH_REDIS_PORT=6379
UPSTASH_API_KEY=
UPSTASH_EMAIL=

# ─── PERPLEXITY (Sonar Pro) ─────────────────────────────────────
PERPLEXITY_API_KEY=

# ─── SENTRY (Error Monitoring) ──────────────────────────────────
SENTRY_AUTH_TOKEN=
SENTRY_PERSONAL_TOKEN=
SENTRY_ORG=
SENTRY_DSN=
SENTRY_PROJECT=

# ─── GITHUB ─────────────────────────────────────────────────────
GITHUB_TOKEN=

# ─── HUGGING FACE ───────────────────────────────────────────────
HF_TOKEN=

# ─── GROQ (Fast LLM) ───────────────────────────────────────────
GROQ_API_KEY=

# ─── CLOUDFLARE ─────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=

# ─── CLAUDE / ANTHROPIC ────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_ORG_ID=

# ─── OPENAI ─────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── GOOGLE / GEMINI ────────────────────────────────────────────
GEMINI_API_KEY=
GOOGLE_API_KEY=
FIREBASE_API_KEY=

# ─── PINECONE (Vector DB) ──────────────────────────────────────
PINECONE_API_KEY=

# ─── STRIPE (Payments) ─────────────────────────────────────────
STRIPE_SECRET_KEY=

# ─── 1PASSWORD (Service Account) ───────────────────────────────
OP_SERVICE_ACCOUNT_TOKEN=
