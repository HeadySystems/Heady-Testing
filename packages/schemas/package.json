{
  "name": "@heady-ai/schemas",
  "version": "1.0.0",
  "description": "HEADY platform shared schema registry with JSON Schema definitions and TypeScript types",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "*.schema.json"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint .",
    "validate-schemas": "node scripts/validate-schemas.js"
  },
  "keywords": [
    "heady",
    "schema",
    "json-schema",
    "validation",
    "typescript"
  ],
  "author": "HEADY Team",
  "license": "MIT",
  "dependencies": {
