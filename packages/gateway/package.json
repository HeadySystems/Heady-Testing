  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HeadyMe/heady-production.git",
    "directory": "packages/gateway"
  },
  "homepage": "https://headysystems.com",
  "bugs": {
    "url": "https://github.com/HeadyMe/heady-production/issues"
  },
  "keywords": [
    "heady",
    "ai",
    "gateway",
    "api-gateway",
    "rate-limiting",
    "auth",
    "cors"
  ],
  "engines": {
    "node": ">=20.0.0"
