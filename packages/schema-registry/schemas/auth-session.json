{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://heady.io/schemas/auth-session.json",
  "title": "AuthSession",
  "description": "Authentication session data for Heady platform users",
  "type": "object",
  "required": ["userId", "email", "provider", "isAnonymous", "createdAt", "expiresAt", "roles"],
  "properties": {
    "userId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique user identifier"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "User email address"
    },
    "provider": {
      "type": "string",
      "enum": ["google", "github", "email", "anonymous", "apple", "microsoft"],
      "description": "Authentication provider used"
    },
    "isAnonymous": {
      "type": "boolean",
      "description": "Whether this is an anonymous session"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Session creation timestamp"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time",
      "description": "Session expiration timestamp"
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "uniqueItems": true,
      "description": "User roles for authorization"
    },
    "displayName": {
      "type": "string",
      "maxLength": 256,
      "description": "User display name"
    },
    "avatarUrl": {
      "type": "string",
      "format": "uri",
      "description": "URL to user avatar image"
    },
    "lastActiveAt": {
      "type": "string",
      "format": "date-time",
      "description": "Last user activity timestamp"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Additional session metadata"
    }
  },
  "additionalProperties": false
}
