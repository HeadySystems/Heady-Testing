{
  "name": "heady-cache",
  "version": "1.0.0",
  "description": "Intelligent semantic cache for the Heady AI platform",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage"
  },
  "keywords": ["cache", "semantic", "embeddings", "vp-tree", "heady", "ai"],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^7.1.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js"],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80
      }
    }
  }
}
