{
  "name": "heady-chain",
  "version": "1.0.0",
  "description": "HeadyChain — Native agent orchestration framework for the Heady AI platform",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "NODE_ENV=development LOG_LEVEL=debug node server.js",
    "test": "NODE_ENV=test HEADY_INFER_MOCK=true node --experimental-vm-modules node_modules/.bin/jest --forceExit --detectOpenHandles",
    "test:watch": "NODE_ENV=test HEADY_INFER_MOCK=true jest --watch",
    "test:coverage": "NODE_ENV=test HEADY_INFER_MOCK=true jest --coverage --forceExit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js"],
    "testTimeout": 30000,
    "verbose": true
  },
  "keywords": [
    "heady",
    "langchain",
    "agent",
    "orchestration",
    "dag",
    "workflow",
    "llm"
  ],
  "author": "Heady AI Platform",
  "license": "UNLICENSED",
  "private": true
}
