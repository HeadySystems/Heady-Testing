{
    "name": "@heady-ai/heady-oracle",
    "version": "1.0.0",
    "description": "HeadyOracle — Knowledge Graph Engine MCP Server",
    "private": true,
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "node --watch src/index.js",
        "docker:build": "docker build -t heady-oracle .",
        "docker:run": "docker run -p 3373:3373 heady-oracle"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.0",
        "hono": "^4.4.0",
        "@hono/node-server": "^1.12.0",
        "dotenv": "^16.4.0"
    },
    "heady": {
        "service": "heady-oracle",
        "port": 3373,
        "category": "data",
        "sacred_geometry_position": "inner_ring",
        "transport": ["sse", "stdio"],
        "deployTargets": ["cloud-run", "cloudflare-workers"]
    }
}
