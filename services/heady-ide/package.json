{
  "name": "@heady-ai/ide-server",
  "version": "1.0.0",
  "description": "HeadyAI-IDE — Browser-native AI development environment",
  "type": "module",
  "main": "heady-ide-server.js",
  "scripts": {
    "start": "node --experimental-vm-modules heady-ide-server.js",
    "dev": "node --watch --experimental-vm-modules heady-ide-server.js",
    "test": "vitest run",
    "lint": "eslint *.js --ext .js",
    "docker:build": "docker build -t heady-ide-server .",
    "docker:run": "docker run -p 8080:8080 --env-file .env.production heady-ide-server",
    "deploy": "gcloud run deploy heady-ide-server --source . --region us-central1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@sentry/node": "^9.0.0",
    "@upstash/redis": "^1.36.0",
    "cors": "^2.8.5",
    "express": "^5.0.1",
    "pg": "^8.13.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "eslint": "^9.16.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "Eric Haywood <eric@headysystems.com>",
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/heady-project/heady-ide"
  }
}
