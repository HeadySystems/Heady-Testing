# Auth Session Server Configuration
PORT=3380
NODE_ENV=production

# Firebase Admin SDK
# Option 1: Path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Option 2: JSON string of service account credentials
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Option 3: Set project ID for Application Default Credentials (GCP)
FIREBASE_PROJECT_ID=heady-platform
