{
  "name": "secret-gateway",
  "version": "3.2.3",
  "type": "module",
  "description": "Secret management \u2014 1Password integration, rotation, vault sync",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "PORT=3396 node --watch index.js",
    "health": "curl -s http://localhost:3396/health | jq ."
  },
  "dependencies": {
    "express": "^5.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/instrumentation-express": "^0.61.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "heady": {
    "domain": "security",
    "port": 3396,
    "architecture": "concurrent-equals",
    "phiScaled": true,
    "autoContext": "mandatory"
  }
}