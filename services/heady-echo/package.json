{
    "name": "@heady/heady-echo",
    "version": "1.0.0",
    "description": "HeadyEcho — Voice & Audio Intelligence MCP Server",
    "private": true,
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "node --watch src/index.js",
        "docker:build": "docker build -t heady-echo .",
        "docker:run": "docker run -p 3372:3372 heady-echo"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.0",
        "hono": "^4.4.0",
        "@hono/node-server": "^1.12.0",
        "dotenv": "^16.4.0"
    },
    "heady": {
        "service": "heady-echo",
        "port": 3372,
        "category": "ai",
        "sacred_geometry_position": "outer_ring",
        "transport": ["sse", "stdio"],
        "deployTargets": ["cloud-run", "cloudflare-workers"]
    }
}
