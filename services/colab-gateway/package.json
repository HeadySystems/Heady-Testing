{
  "name": "colab-gateway",
  "version": "3.2.3",
  "type": "module",
  "description": "Colab integration \u2014 GPU burst compute, notebook execution",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "PORT=3386 node --watch index.js",
    "health": "curl -s http://localhost:3386/health | jq ."
  },
  "dependencies": {
    "express": "^5.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/instrumentation-express": "^0.61.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "heady": {
    "domain": "integration",
    "port": 3386,
    "architecture": "concurrent-equals",
    "phiScaled": true,
    "autoContext": "mandatory"
  }
}