{
  "name": "heady-vector",
  "version": "1.0.0",
  "description": "Production-ready vector search service for Heady AI using pgvector",
  "main": "server.js",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --runInBand",
    "test:verbose": "jest --runInBand --verbose",
    "test:coverage": "jest --runInBand --coverage"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^7.1.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 60000,
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  }
}
