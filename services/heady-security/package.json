{
  "name": "heady-security",
  "version": "3.2.3",
  "type": "module",
  "description": "Security scanning \u2014 vulnerability detection, threat analysis",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "PORT=3331 node --watch index.js",
    "health": "curl -s http://localhost:3331/health | jq ."
  },
  "dependencies": {
    "express": "^4.21.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/instrumentation-express": "^0.61.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "heady": {
    "domain": "security",
    "port": 3331,
    "architecture": "concurrent-equals",
    "phiScaled": true,
    "autoContext": "mandatory"
  }
}