{
  "mcpServers": {
    "heady": {
      "transport": "streamable-http",
      "url": "https://headymcp.com/mcp",
      "headers": {
        "Authorization": "Bearer ${HEADY_API_KEY}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "../../.."
      ]
    }
  },
  "taskPipeline": {
    "configPath": "configs/cloud-config.json",
    "sources": {
      "hcfp": "configs/hcfullpipeline-tasks.json",
      "masterBoard": "docs/MASTER-TASK-BOARD.md",
      "strategic": "docs/extracted-tasks.md",
      "enterprise": "docs/enterprise-task-extraction.md",
      "autoSuccess": "data/auto-success-tasks.json",
      "improvements": "data/improvement-tasks.json"
    },
    "infrastructure": {
      "scheduler": "src/hc_task_scheduler.js",
      "dispatcher": "task-dispatcher.js",
      "orchestrator": "battle-sim-task-orchestrator.js",
      "migration": "migrations/004_task_queue.sql"
    }
  }
}
