{
  "name": "@heady-ai/mcp-server",
  "version": "5.1.0",
  "description": "Heady™ Master Control Program — 97+ MCP tools, stdio/HTTP/SSE transports, φ-scaled routing, CSL gates",
  "main": "src/index.js",
  "bin": {
    "heady-mcp-server": "src/index.js"
  },
  "files": [
    "src/",
    "new-tools/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node index.js",
    "start:stdio": "HEADY_MCP_TRANSPORT=stdio node index.js",
    "start:http": "HEADY_MCP_TRANSPORT=http node index.js",
    "start:sse": "HEADY_MCP_TRANSPORT=sse node index.js",
    "dev": "node --watch index.js",
    "test": "node --test src/__tests__/*.test.js",
    "health": "curl -s http://localhost:3310/health | node -e \"process.stdin.pipe(process.stdout)\""
  },
  "engines": { "node": ">=20.0.0" },
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.4.0",
    "uuid": "^9.0.1",
    "ws": "^8.18.1",
    "pino": "^8.21.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {},
  "author": "HeadySystems Inc. <eric@headyconnection.org>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HeadyMe/Heady-pre-production-9f2f0642.git",
    "directory": "services/heady-mcp-server"
  },
  "homepage": "https://headymcp.com",
  "keywords": ["heady", "mcp", "model-context-protocol", "ai", "tools", "phi-scaled"]
}
