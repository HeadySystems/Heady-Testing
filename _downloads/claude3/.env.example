# ═══════════════════════════════════════════════════════════════
# HEADY SYSTEM — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ═══════════════════════════════════════════════════════════════

# ─── Application ───
NODE_ENV=development
HEADY_VERSION=3.0.0
PORT=3000
HOST=0.0.0.0

# ─── Database (PostgreSQL) ───
# Format: postgresql://user:password@host:port/database
# CRITICAL: Use strong passwords. Never use default credentials.
DATABASE_URL=postgresql://heady_user:CHANGE_ME_STRONG_PASSWORD@db.example.com:5432/heady_production
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── Redis (Agent Communication Bus) ───
# Format: redis://[:password@]host:port[/database]
REDIS_URL=redis://redis.example.com:6379
REDIS_POOL_MIN=2
REDIS_POOL_MAX=13

# ─── Authentication ───
# CRITICAL: Generate with: openssl rand -hex 32
# Must be at least 32 characters in production
JWT_SECRET=GENERATE_WITH_openssl_rand_hex_32
TOKEN_EXPIRY=15m
REFRESH_EXPIRY=7d

# ─── MCP Server ───
MCP_GATEWAY_URL=https://manager.headysystems.com/mcp/sse
MCP_TIMEOUT_MS=5000

# ─── CORS (comma-separated list of allowed origins) ───
# CRITICAL: Never use '*' in production
ALLOWED_ORIGINS=https://manager.headysystems.com,https://dashboard.headysystems.com

# ─── Trading (Apex Trader Funding) ───
# Use demo URLs for development, live URLs for production
TRADOVATE_API_URL=https://demo.tradovateapi.com/v1
TRADOVATE_WS_URL=wss://demo.tradovateapi.com/v1/websocket
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_APP_VERSION=
MAX_DRAWDOWN_PCT=100
CONSISTENCY_RULE_PCT=30
AUTOCLOSE_TIME_ET=16:58

# ─── Rithmic (Market Data) ───
RITHMIC_URI=
RITHMIC_USER=
RITHMIC_PASSWORD=

# ─── External APIs ───
ALPHAVANTAGE_API_KEY=
BRIGHT_DATA_API_KEY=

# ─── Observability ───
LOG_LEVEL=info
ENABLE_TRACING=false
METRICS_PORT=9090

# ─── Colab Pro+ Runtimes (Latent Space Ops) ───
# URLs of the FastAPI model serving endpoints on each Colab runtime
COLAB_RUNTIME_1_URL=
COLAB_RUNTIME_2_URL=
COLAB_RUNTIME_3_URL=

# ─── Notifications ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=

# ─── Feature Flags ───
ENABLE_PERSISTENT_CONFIG=true
RESET_CONFIG_ON_START=false
