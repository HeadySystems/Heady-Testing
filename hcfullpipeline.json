      "ttl": 300
    },
    "cost_usd": {
      "description": "Max cost per pipeline run in USD",
      "default": 1.00,
      "max": 10.00,
      "fullAutoMax": 5.00,
      "trackingEnabled": true
    }
  },
  "timeouts": {
    "total_pipeline": 300000,
    "per_stage_default": 29034,
    "per_stage_default_source": "φ⁷ × 1000",
    "per_step_default": 11090,
    "per_step_default_source": "φ⁵ × 1000",
    "llm_call": 46979,
    "llm_call_source": "φ⁸ × 1000",
    "embedding": 6854,
    "embedding_source": "φ⁴ × 1000",
    "db_query": 4236,
    "db_query_source": "φ³ × 1000",
    "governance_check": 4236,
    "governance_check_source": "φ³ × 1000",
