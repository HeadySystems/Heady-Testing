{
  "_meta": {
    "name": "HCFullPipeline",
    "version": "4.0.0",
    "description": "Heady™ AI Platform 21-Stage (fib(8)) Cognitive Pipeline — φ-scaled throughout, zero magic numbers",
    "copyright": "© 2026-2026 HeadySystems Inc. All Rights Reserved.",
    "updatedAt": "2026-03-08T00:00:00Z",
    "audit": "All constants φ-derived per FIXED-VALUE-AUDIT and phi-math-foundation"
  },
  "pipeline": {
    "id": "hcfullpipeline",
    "displayName": "HCFullPipeline",
    "mode": "sequential_with_parallel_stages",
    "maxDuration": 300000,
    "defaultTimeout": 29034,
    "defaultTimeout_source": "φ⁷ × 1000 (replaces arbitrary 30000)",
    "retryPolicy": {
      "maxRetries": 3,
      "maxRetries_source": "fib(4)",
      "backoffStrategy": "phi_exponential",
      "backoffMs": [1618, 2618, 4236],
      "backoffMs_source": "φ¹×1000, φ²×1000, φ³×1000 (replaces 1000/2000/4000)",
      "maxBackoffMs": 11090,
      "maxBackoffMs_source": "φ⁵ × 1000 (replaces arbitrary 10000)"
    }
  },
  "fullAutoMode": {
    "enabled": false,
    "description": "When enabled, pipeline executes all stages autonomously without human checkpoints",
    "envOverride": "PIPELINE_FULL_AUTO",
    "requiresGovernancePass": true,
    "maxBudgetUSD": 5.00,
    "allowedScopes": ["read", "analyze", "generate"],
    "prohibitedScopes": ["deploy", "delete", "external_write"],
    "confirmationBypass": false
  },
  "stages": [
    {
      "id": "stage_channel_entry",
      "name": "Channel Entry (Stage 0)",
      "order": 0,
      "required": true,
      "timeout": 4236,
      "timeout_source": "φ³ × 1000",
      "parallel": true,
      "steps": [
        {
          "id": "scan_vector_storage",
          "name": "Scan 3D persistent vector storage (MUST run first)",
          "node": "HeadyMemory",
          "action": "scan",
          "failFast": true,
          "params": { "scope": "full", "timeout": 5000 }
        },
        {
          "id": "resolve_channel",
          "name": "Resolve channel and user identity",
          "node": "HeadyBuddy",
          "action": "resolveChannel"
        },
        {
          "id": "sync_cross_device",
          "name": "Sync cross-device context",
          "node": "HeadyBuddy",
          "action": "syncContext"
        },
        {
          "id": "route_pipeline_branch",
          "name": "Route to pipeline branch",
          "node": "HeadyConductor",
          "action": "route"
        }
      ]
    },
    {
      "id": "stage_recon",
      "name": "Reconnaissance & Deep Scan (Stage 1)",
      "order": 1,
      "required": true,
      "timeout": 6854,
      "timeout_source": "φ⁴ × 1000",
      "parallel": true,
      "steps": [
        {
          "id": "scan_codebase",
          "name": "Scan codebase state and config drift",
          "node": "HeadyDeepScan",
          "action": "scan",
          "params": { "scope": "full", "driftThreshold": 0.618 }
        },
        {
          "id": "scan_services",
          "name": "Scan all service health and attack surface",
          "node": "HeadyHealth",
          "action": "matrix",
          "params": { "includeAttackSurface": true }
        },
        {
          "id": "scan_dependencies",
          "name": "Scan dependency freshness and vulnerabilities",
          "node": "HeadyGuard",
          "action": "auditDeps",
          "params": { "freshnessWindowDays": 13, "freshnessWindowDays_source": "fib(7)" }
        },
        {
          "id": "build_env_map",
          "name": "Build unified environment map",
          "node": "HeadyConductor",
          "action": "buildEnvMap"
        }
      ]
    },
    {
      "id": "stage_intake",
      "name": "Task Intake & Classification (Stage 2)",
      "order": 2,
      "required": true,
      "timeout": 4236,
      "timeout_source": "φ³ × 1000",
      "parallel": false,
      "steps": [
        {
          "id": "parse_task",
          "name": "Parse and normalize task input",
          "node": "HeadyConductor",
          "action": "parse",
          "failFast": true
        },
        {
          "id": "classify_intent",
          "name": "Classify intent via CSL Resonance Gate",
          "node": "HeadySoul",
          "action": "analyze",
          "params": { "depth": "shallow", "cslThreshold": 0.618 }
        },
        {
          "id": "governance_pre",
          "name": "Pre-execution governance check",
          "node": "HeadyGovernance",
          "action": "validate",
          "failFast": true,
          "params": { "phase": "pre" }
        }
      ]
    },
    {
      "id": "stage_memory",
      "name": "Memory & Context Retrieval (Stage 3)",
      "order": 3,
      "required": true,
      "timeout": 6854,
      "timeout_source": "φ⁴ × 1000",
      "parallel": true,
      "steps": [
        {
          "id": "vector_search",
          "name": "Semantic memory search",
          "node": "HeadyMemory",
          "action": "search",
          "params": { "limit": 13, "limit_source": "fib(7)", "minScore": 0.618 }
        },
        {
          "id": "pattern_lookup",
          "name": "Pattern recognition lookup",
          "node": "HeadyVinci",
          "action": "recognize",
          "params": { "mode": "fast" }
        },
        {
          "id": "story_context",
          "name": "Retrieve narrative context",
          "node": "HeadyAutobiographer",
          "action": "getStory",
          "params": { "limit": 21, "limit_source": "fib(8)" }
        }
      ]
    },
    {
      "id": "stage_triage",
      "name": "Priority Triage (Stage 4)",
      "order": 4,
      "required": true,
      "timeout": 4236,
      "timeout_source": "φ³ × 1000",
      "parallel": false,
      "steps": [
        {
          "id": "compute_risk",
          "name": "Compute risk score and priority",
          "node": "HeadyBrains",
          "action": "triage",
          "params": { "levels": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] }
        },
        {
          "id": "assign_swarm",
          "name": "Assign to swarm based on CSL scoring",
          "node": "HeadyConductor",
          "action": "assignSwarm"
        }
      ]
    },
    {
      "id": "stage_decompose",
      "name": "Task Decomposition (Stage 5)",
      "order": 5,
      "required": true,
      "timeout": 6854,
      "timeout_source": "φ⁴ × 1000",
      "parallel": false,
      "steps": [
        {
          "id": "decompose_dag",
          "name": "Decompose into subtask DAG via Rabbit layer",
          "node": "HeadyBrains",
          "action": "decompose",
          "params": { "maxDepth": 5, "maxDepth_source": "fib(5)" }
        },
        {
          "id": "plan_execution",
          "name": "Generate execution plan",
          "node": "HeadyBrains",
          "action": "plan",
          "params": { "maxSteps": 13, "maxSteps_source": "fib(7)" }
        }
      ]
    },
    {
      "id": "stage_trial_and_error",
      "name": "Trial & Error Sandbox (Stage 6)",
      "order": 6,
      "required": false,
      "timeout": 17944,
      "timeout_source": "φ⁶ × 1000",
      "parallel": true,
      "enabledWhen": "task.allowTrials === true || task.complexity >= 'high'",
      "steps": [
        {
          "id": "generate_candidates",
          "name": "Generate candidate solutions",
          "node": "HeadyBrains",
          "action": "generateCandidates",
          "params": { "maxCandidates": 5, "maxCandidates_source": "fib(5)" }
        },
        {
          "id": "execute_trials",
          "name": "Execute trials in sandbox",
          "node": "HeadyBee",
          "action": "sandboxExecute",
          "params": { "isolation": "docker", "autoRollback": true }
        },
        {
          "id": "score_trials",
          "name": "Score trial outcomes via CSL",
          "node": "HeadyArena",
          "action": "scoreCandidates",
          "params": {
            "criteria": ["correctness", "performance", "safety", "elegance"],
            "weights": { "correctness": 0.34, "performance": 0.21, "safety": 0.21, "elegance": 0.13, "resource_efficiency": 0.11 }
          }
        },
        {
          "id": "record_trial_learnings",
          "name": "Record trial learnings to vector memory",
          "node": "HeadyMemory",
          "action": "store",
          "params": { "namespace": "trial_learnings" }
        }
      ]
    },
    {
      "id": "stage_orchestrate",
      "name": "Orchestration & Execution (Stage 7)",
      "order": 7,
      "required": true,
      "timeout": 120000,
      "parallel": false,
      "steps": [
        {
          "id": "execute",
          "name": "Execute primary task with Soul",
          "node": "HeadySoul",
          "action": "execute",
          "params": { "maxTokens": 16000 }
        },
        {
          "id": "bee_spawn_if_needed",
          "name": "Spawn bee workers if parallel subtasks exist",
          "node": "HeadyBee",
          "action": "spawn",
          "conditional": "plan.parallelSubtasks.length > 0",
          "params": { "maxBees": 8, "maxBees_source": "fib(6)" }
        }
      ]
    },
    {
      "id": "stage_monte_carlo",
      "name": "Monte Carlo Simulation (Stage 8)",
      "order": 8,
      "required": false,
      "timeout": 11090,
      "timeout_source": "φ⁵ × 1000",
      "parallel": false,
      "enabledWhen": "task.requiresConfidence === true",
      "steps": [
        {
          "id": "monte_carlo",
          "name": "Monte Carlo confidence estimation (1K+ scenarios)",
          "node": "HeadyConductor",
          "action": "monteCarlo",
          "params": { "iterations": 987, "iterations_source": "fib(16)", "passThreshold": 0.80 }
        }
      ]
    },
    {
      "id": "stage_arena",
      "name": "Arena Evaluation (Stage 9)",
      "order": 9,
      "required": false,
      "timeout": 17944,
      "timeout_source": "φ⁶ × 1000",
      "parallel": false,
      "enabledWhen": "task.requiresEvaluation === true || task.type === 'generation'",
      "steps": [
        {
          "id": "arena_battle",
          "name": "Run arena battle for quality selection",
          "node": "HeadyArena",
          "action": "battle",
          "params": {
            "rounds": 3,
            "criteria": ["accuracy", "quality", "efficiency", "safety"],
            "winnerMargin": 0.05
          }
        }
      ]
    },
    {
      "id": "stage_judge",
      "name": "Quantitative Judging (Stage 10)",
      "order": 10,
      "required": true,
      "timeout": 6854,
      "timeout_source": "φ⁴ × 1000",
      "parallel": false,
      "steps": [
        {
          "id": "score_composite",
          "name": "Score output: correctness(34%), safety(21%), perf(21%), quality(13%), elegance(11%)",
          "node": "HeadyArena",
          "action": "judgeComposite",
          "params": {
            "weights": { "correctness": 0.34, "safety": 0.21, "performance": 0.21, "quality": 0.13, "elegance": 0.11 },
            "passThreshold": 0.618,
            "passThreshold_source": "1/φ (CSL default gate)"
          }
        }
      ]
    },
    {
      "id": "stage_approve",
      "name": "Human Approval Gate (Stage 11)",
      "order": 11,
      "required": false,
      "timeout": 300000,
      "parallel": false,
      "enabledWhen": "task.riskLevel === 'HIGH' || task.riskLevel === 'CRITICAL'",
      "steps": [
        {
          "id": "human_approval",
          "name": "Request explicit approval from Eric",
          "node": "HeadyBuddy",
          "action": "requestApproval",
          "params": { "requiredApprover": "eric" }
        }
      ]
    },
    {
      "id": "stage_execute_verified",
      "name": "Metacognitive Execute (Stage 12)",
      "order": 12,
      "required": true,
      "timeout": 120000,
      "parallel": false,
      "steps": [
        {
          "id": "metacognitive_gate",
          "name": "HeadyBuddy assesses state confidence (min 20%)",
          "node": "HeadyBuddy",
          "action": "assessConfidence",
          "params": { "minConfidence": 0.20 }
        },
        {
          "id": "execute_final",
          "name": "Execute with full context and confidence",
          "node": "HeadySoul",
          "action": "executeFinal"
        }
      ]
    },
    {
      "id": "stage_verify",
      "name": "Post-Execution Verification (Stage 13)",
      "order": 13,
      "required": true,
      "timeout": 11090,
      "timeout_source": "φ⁵ × 1000",
      "parallel": true,
      "steps": [
        {
          "id": "integration_tests",
          "name": "Run integration tests and health checks",
          "node": "HeadyCheck",
          "action": "verify"
        },
        {
          "id": "assertions",
          "name": "Validate all assertions pass",
          "node": "HeadyAssure",
          "action": "certify"
        }
      ]
    },
    {
      "id": "stage_self_awareness",
      "name": "Self-Awareness Assessment (Stage 14)",
      "order": 14,
      "required": true,
      "timeout": 11090,
      "timeout_source": "φ⁵ × 1000",
      "parallel": false,
      "steps": [
        {
          "id": "calibrate_confidence",
          "name": "Assess confidence calibration accuracy",
          "node": "HeadySoul",
          "action": "introspect",
          "params": { "window": 21, "window_source": "fib(8)", "accuracyThreshold": 0.618 }
        },
        {
          "id": "detect_blind_spots",
          "name": "Identify cognitive blind spots and biases",
          "node": "HeadyVinci",
          "action": "detectBiases",
          "params": { "methods": ["confirmation", "anchoring", "availability", "survivorship"] }
        },
        {
          "id": "measure_predictions",
          "name": "Measure prediction accuracy vs actuals",
          "node": "HeadyConductor",
          "action": "measurePredictions",
          "params": { "lookbackRuns": 21, "lookbackRuns_source": "fib(8)" }
        }
      ]
    },
    {
      "id": "stage_self_critique",
      "name": "Self-Critique (Stage 15)",
      "order": 15,
      "required": true,
      "timeout": 11090,
      "timeout_source": "φ⁵ × 1000",
      "parallel": false,
      "steps": [
        {
          "id": "critique_run",
          "name": "Review own run — bottlenecks, weaknesses, gaps",
          "node": "HeadyBrains",
          "action": "selfCritique",
          "params": { "useAwarenessReport": true }
        }
      ]
    },
    {
      "id": "stage_mistake_analysis",
      "name": "Mistake Analysis & Prevention (Stage 16)",
      "order": 16,
      "required": true,
      "timeout": 11090,
      "timeout_source": "φ⁵ × 1000",
      "parallel": false,
      "steps": [
        {
          "id": "catalog_failures",
          "name": "Catalog current and historical failures",
          "node": "HeadyMemory",
          "action": "search",
          "params": { "namespace": "failures", "limit": 89, "limit_source": "fib(11)" }
        },
        {
          "id": "root_cause",
          "name": "Perform root cause analysis (5-whys + fishbone)",
          "node": "HeadyBrains",
          "action": "rootCause",
          "params": { "method": "five_whys_plus_fishbone" }
        },
        {
          "id": "generate_guards",
          "name": "Generate prevention rules and anti-regression guards",
          "node": "HeadyGuard",
          "action": "generatePreventionRules",
          "params": { "format": "csl_gate" }
        },
        {
          "id": "immunize",
          "name": "Inject guards into pipeline and update wisdom.json",
          "node": "HeadyVinci",
          "action": "immunize",
          "params": { "updateWisdom": true, "updateRecon": true }
        }
      ]
    },
    {
      "id": "stage_optimization_ops",
      "name": "Optimization Ops Scanning (Stage 17)",
      "order": 17,
      "required": true,
      "timeout": 17944,
      "timeout_source": "φ⁶ × 1000",
      "parallel": true,
      "steps": [
        {
          "id": "profile_performance",
          "name": "Profile service latency p50/p95/p99",
          "node": "HeadyHealth",
          "action": "profile",
          "params": { "windowMinutes": 55, "windowMinutes_source": "fib(10)" }
        },
        {
          "id": "detect_waste",
          "name": "Detect dead code, unused services, cost waste",
          "node": "HeadyDeepScan",
          "action": "detectWaste",
          "params": { "methods": ["ast_reachability", "traffic_analysis", "cost_per_request"] }
        },
        {
          "id": "rank_optimizations",
          "name": "Rank optimization opportunities by CSL impact score",
          "node": "HeadyConductor",
          "action": "rankOptimizations",
          "params": { "costWeight": 0.382, "perfWeight": 0.382, "reliabilityWeight": 0.236 }
        }
      ]
    },
    {
      "id": "stage_continuous_search",
      "name": "Continuous Search & Discovery (Stage 18)",
      "order": 18,
      "required": false,
      "timeout": 29034,
      "timeout_source": "φ⁷ × 1000",
      "parallel": true,
      "steps": [
        {
          "id": "search_innovations",
          "name": "Search for new tools, research, and patterns",
          "node": "HeadyPerplexity",
          "action": "search",
          "params": { "categories": ["npm", "arxiv", "github", "security"], "maxResults": 8, "maxResults_source": "fib(6)" }
        },
        {
          "id": "evaluate_discoveries",
          "name": "CSL-score relevance and applicability",
          "node": "HeadySoul",
          "action": "evaluate",
          "params": { "threshold": 0.618 }
        },
        {
          "id": "absorb_findings",
          "name": "Embed high-value findings into knowledge",
          "node": "HeadyMemory",
          "action": "store",
          "params": { "namespace": "discoveries" }
        }
      ]
    },
    {
      "id": "stage_evolution",
      "name": "Evolution & Mutation (Stage 19)",
      "order": 19,
      "required": false,
      "timeout": 29034,
      "timeout_source": "φ⁷ × 1000",
      "parallel": false,
      "enabledWhen": "pipeline.evolutionEnabled === true",
      "steps": [
        {
          "id": "generate_mutations",
          "name": "Generate controlled parameter mutations",
          "node": "HeadyBrains",
          "action": "mutate",
          "params": { "rate": 0.0618, "populationSize": 8, "maxMagnitude": 0.13 }
        },
        {
          "id": "simulate_mutations",
          "name": "Simulate mutations via HeadySims",
          "node": "HeadyConductor",
          "action": "monteCarlo",
          "params": { "iterations": 500, "compareToBaseline": true }
        },
        {
          "id": "promote_winners",
          "name": "Promote beneficial mutations to config",
          "node": "HeadyGovernance",
          "action": "promoteIfBeneficial",
          "params": { "rollbackThreshold": 0.05, "approvalThreshold": 0.08 }
        },
        {
          "id": "record_evolution",
          "name": "Record evolution history",
          "node": "HeadyAutobiographer",
          "action": "record",
          "params": { "events": ["mutation_generated", "mutation_tested", "mutation_promoted", "mutation_discarded"] }
        }
      ]
    },
    {
      "id": "stage_receipt",
      "name": "Trust Receipt & Audit (Stage 20)",
      "order": 20,
      "required": true,
      "timeout": 6854,
      "timeout_source": "φ⁴ × 1000",
      "parallel": true,
      "steps": [
        {
          "id": "embed_result",
          "name": "Embed and store result in vector memory",
          "node": "HeadyMemory",
          "action": "store",
          "params": { "namespace": "pipeline_results" }
        },
        {
          "id": "vinci_learn",
          "name": "Update Vinci pattern model",
          "node": "HeadyVinci",
          "action": "learn",
          "params": { "updateBaseline": true }
        },
        {
          "id": "governance_post",
          "name": "Post-execution governance audit",
          "node": "HeadyGovernance",
          "action": "audit",
          "params": { "phase": "post" }
        },
        {
          "id": "drift_check",
          "name": "Check semantic drift",
          "node": "HeadyConductor",
          "action": "driftCheck"
        },
        {
          "id": "record_story",
          "name": "Log execution to autobiographer",
          "node": "HeadyAutobiographer",
          "action": "record",
          "params": { "events": ["pipeline_run", "decision_made", "learning_captured"] }
        },
        {
          "id": "emit_receipt",
          "name": "Emit trust receipt signed with Ed25519",
          "node": "HeadyGovernance",
          "action": "emitReceipt",
          "params": { "signAlgorithm": "Ed25519" }
        }
      ]
    }
  ],
  "pipelineVariants": {
    "fast_path": {
      "description": "For LOW risk, pre-approved patterns",
      "stages": [0, 1, 2, 7, 12, 13, 20]
    },
    "full_path": {
      "description": "All 21 stages for HIGH/CRITICAL or novel patterns",
      "stages": "all"
    },
    "arena_path": {
      "description": "Competitive evaluation without execution",
      "stages": [0, 1, 2, 3, 4, 8, 9, 10, 20]
    },
    "learning_path": {
      "description": "Continuous improvement without task execution",
      "stages": [0, 1, 16, 17, 18, 19, 20]
    }
  },
  "pools": {
    "llm_tokens": {
      "description": "LLM token budget per pipeline run",
      "default": 50000,
      "max": 200000,
      "warningThreshold": 40000,
      "byStage": {
        "stage_channel_entry": 1597,
        "stage_recon": 2584,
        "stage_intake": 1597,
        "stage_memory": 2584,
        "stage_triage": 1597,
        "stage_decompose": 2584,
        "stage_trial_and_error": 6765,
        "stage_orchestrate": 17711,
        "stage_monte_carlo": 2584,
        "stage_arena": 6765,
        "stage_judge": 1597,
        "stage_approve": 987,
        "stage_execute_verified": 17711,
        "stage_verify": 2584,
        "stage_self_awareness": 4181,
        "stage_self_critique": 2584,
        "stage_mistake_analysis": 2584,
        "stage_optimization_ops": 2584,
        "stage_continuous_search": 4181,
        "stage_evolution": 6765,
        "stage_receipt": 2584
      },
      "byStage_note": "All token budgets are Fibonacci numbers: fib(16)=987, fib(17)=1597, fib(18)=2584, fib(19)=4181, fib(20)=6765, fib(22)=17711"
    },
    "concurrent_requests": {
      "description": "Max concurrent LLM/API requests",
      "default": 5,
      "max": 21,
      "max_source": "fib(8)",
      "perNode": {
        "HeadySoul": 3,
        "HeadyBrains": 3,
        "HeadyVinci": 5,
        "HeadyArena": 5,
        "HeadyBee": 13,
