<nav class="heady-nav">
  <div class="nav-container">
    <a href="/" class="nav-logo">
      <span class="logo-dot"></span>
      <span class="logo-text">{{ site.name or "Heady Systems" }}</span>
    </a>
    <div class="nav-links">
      {% for link in site.nav %}
      <a href="{{ link.url }}" class="nav-link{% if page.url == link.url %} active{% endif %}">{{ link.label }}</a>
      {% endfor %}
    </div>
  </div>
</nav>
