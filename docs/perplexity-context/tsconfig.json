{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": [
            "ES2022"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "allowJs": true,
        "checkJs": false,
        "noEmit": false,
        "moduleResolution": "node",
        "types": [
            "node",
            "jest"
        ],
        "baseUrl": ".",
        "paths": {
            "@heady-ai/config/*": [
                "src/config/*"
            ],
            "@heady-ai/orchestration/*": [
                "src/orchestration/*"
            ],
            "@heady-ai/memory/*": [
                "src/memory/*"
            ],
            "@heady-ai/auth/*": [
                "src/auth/*"
            ],
            "@heady-ai/mcp/*": [
                "src/mcp/*"
            ],
            "@heady-ai/agents/*": [
                "src/agents/*"
            ],
            "@heady-ai/observability/*": [
                "src/observability/*"
            ],
            "@heady-ai/shared/*": [
                "src/shared/*"
            ]
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.js"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "_archive",
        "tests"
    ]
}