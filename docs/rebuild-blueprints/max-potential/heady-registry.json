      "packages/heady-core"
    ],
    "headybot-core": [
      "services/headybot",
      "packages/heady-core",
      "packages/heady-contracts"
    ],
    "headyio-core": [
      "packages/heady-sdk",
      "packages/heady-contracts",
      "docs/architecture"
    ]
