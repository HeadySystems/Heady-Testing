      "product": "HeadyMe",
      "type": "experience"
    },
    "headybuddy.org": {
      "product": "HeadyBuddy",
      "type": "experience"
    },
    "headyconnection.org": {
      "product": "HeadyConnection",
      "type": "experience"
    },
    "headyapi.com": {
      "product": "HeadyAPI",
      "type": "intelligence"
    },
    "headymcp.com": {
      "product": "HeadyMCP",
      "type": "intelligence"
    },
    "headysystems.com": {
