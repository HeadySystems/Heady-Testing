# Database
DATABASE_URL="postgresql://user:password@localhost:5432/heady_pilot"

# Auth.js
NEXTAUTH_URL="https://headyme.com"
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars"

# OAuth Providers (25+ supported - add your keys)
# Google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub
GITHUB_ID="your-github-id"
GITHUB_SECRET="your-github-secret"

# HuggingFace
HUGGINGFACE_ID="your-hf-id"
HUGGINGFACE_SECRET="your-hf-secret"

# Microsoft
MICROSOFT_CLIENT_ID="your-microsoft-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-secret"

# Apple
APPLE_ID="your-apple-id"
APPLE_SECRET="your-apple-secret"

# Discord
DISCORD_CLIENT_ID="your-discord-id"
DISCORD_CLIENT_SECRET="your-discord-secret"

# Twitter/X
TWITTER_CLIENT_ID="your-twitter-id"
TWITTER_CLIENT_SECRET="your-twitter-secret"

# LinkedIn
LINKEDIN_CLIENT_ID="your-linkedin-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-secret"

# Auth0
AUTH0_CLIENT_ID="your-auth0-id"
AUTH0_CLIENT_SECRET="your-auth0-secret"
AUTH0_ISSUER="https://your-domain.auth0.com"

# Okta
OKTA_CLIENT_ID="your-okta-id"
OKTA_CLIENT_SECRET="your-okta-secret"
OKTA_ISSUER="https://your-domain.okta.com"

# Add 15+ more providers as needed

# Email Configuration
EMAIL_PROVIDER="cloudflare" # or "resend" or "sendgrid"
CLOUDFLARE_API_TOKEN="your-cloudflare-token"
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account"
CLOUDFLARE_ZONE_ID="your-zone-id"

# HeadyCloud Integration
HEADYCLOUD_API_URL="https://api.headycloud.com"
HEADYCLOUD_API_KEY="your-headycloud-key"

# HeadyMCP Integration
HEADYMCP_URL="https://headymcp.com"
HEADYMCP_API_KEY="your-headymcp-key"

# HeadyBuddy Configuration
HEADYBUDDY_API_URL="https://api.headybuddy.org"
HEADYBUDDY_API_KEY="your-headybuddy-key"

# Feature Flags
ENABLE_EMAIL_CLIENT="true"
ENABLE_HYBRID_FILESYSTEM="true"
ENABLE_BUDDY_ONBOARDING="true"
