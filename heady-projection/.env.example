# Heady Projection System — Environment Variables

# Service ports
PROJECTION_PORT=3849
DASHBOARD_PORT=3850

# Logging
HEADY_DEBUG=false
LOG_LEVEL=info

# Cloud Run (production)
GOOGLE_CLOUD_PROJECT=heady-production
PUBSUB_SUBSCRIPTION_PREFIX=heady-projection
CLOUD_RUN_SERVICE_URL=https://projection.heady.run

# Redis (optional caching)
REDIS_URL=redis://localhost:6379

# Admin token for mutation endpoints
HEADY_ADMIN_TOKEN=

# Conductor connection
HEADY_CLOUD_CONTROL_URL=
HEADY_EDGE_URL=

# Retry budget
HEADY_RETRY_BUDGET_PER_TASK=3
HEADY_DLQ_MAX=500
