{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "composite": true,
    "incremental": true,
    "paths": {
      "@heady-ai/shared-types": ["./packages/shared-types/src/index.js"],
      "@heady-ai/shared-types/*": ["./packages/shared-types/src/*"],
      "@heady-ai/shared-utils": ["./packages/shared-utils/src/index.js"],
      "@heady-ai/shared-utils/*": ["./packages/shared-utils/src/*"]
    }
  },
  "include": [],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "./packages/shared-types" },
    { "path": "./packages/shared-utils" },
    { "path": "./apps/projection-service" },
    { "path": "./apps/dashboard" }
  ]
}
