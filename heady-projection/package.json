{
  "name": "heady-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Heady™ AI Platform — Autonomous Projection Monorepo",
  "author": "HeadySystems Inc.",
  "license": "UNLICENSED",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "scaffold": "node scripts/scaffold-cli.js",
    "generate:bee": "node scripts/generate-bee.js",
    "projection:start": "node apps/projection-service/index.js",
    "projection:dev": "nodemon apps/projection-service/index.js",
    "dashboard": "node apps/dashboard/server.js"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "nodemon": "^3.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
