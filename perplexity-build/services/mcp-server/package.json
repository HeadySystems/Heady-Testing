{
  "name": "mcp-server",
  "version": "3.2.3",
  "type": "module",
  "description": "MCP protocol server \u2014 31 registered tools, stdio+HTTP transport",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "PORT=3380 node --watch index.js",
    "health": "curl -s http://localhost:3380/health | jq ."
  },
  "dependencies": {
    "express": "^4.21.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.0",
    "@opentelemetry/instrumentation-express": "^0.41.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "heady": {
    "domain": "integration",
    "port": 3380,
    "architecture": "concurrent-equals",
    "phiScaled": true,
    "autoContext": "mandatory"
  }
}