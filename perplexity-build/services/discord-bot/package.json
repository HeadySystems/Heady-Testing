{
  "name": "discord-bot",
  "version": "3.2.3",
  "type": "module",
  "description": "Discord bot \u2014 community interaction, notifications, commands",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "PORT=3388 node --watch index.js",
    "health": "curl -s http://localhost:3388/health | jq ."
  },
  "dependencies": {
    "express": "^4.21.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.0",
    "@opentelemetry/instrumentation-express": "^0.41.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "heady": {
    "domain": "integration",
    "port": 3388,
    "architecture": "concurrent-equals",
    "phiScaled": true,
    "autoContext": "mandatory"
  }
}