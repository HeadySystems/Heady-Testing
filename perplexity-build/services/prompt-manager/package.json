{
  "name": "prompt-manager",
  "version": "3.2.3",
  "type": "module",
  "description": "Prompt management \u2014 64-prompt catalogue, template rendering",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "PORT=3395 node --watch index.js",
    "health": "curl -s http://localhost:3395/health | jq ."
  },
  "dependencies": {
    "express": "^5.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.0",
    "@opentelemetry/instrumentation-express": "^0.41.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "heady": {
    "domain": "orchestration",
    "port": 3395,
    "architecture": "concurrent-equals",
    "phiScaled": true,
    "autoContext": "mandatory"
  }
}