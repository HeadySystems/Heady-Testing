{
  "name": "heady-cache",
  "version": "3.2.3",
  "type": "module",
  "description": "Caching layer \u2014 hot/warm/cold with \u03c6-scaled TTLs, LRU eviction",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "PORT=3363 node --watch index.js",
    "health": "curl -s http://localhost:3363/health | jq ."
  },
  "dependencies": {
    "express": "^4.21.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.0",
    "@opentelemetry/instrumentation-express": "^0.41.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "heady": {
    "domain": "data",
    "port": 3363,
    "architecture": "concurrent-equals",
    "phiScaled": true,
    "autoContext": "mandatory"
  }
}