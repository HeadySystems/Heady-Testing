{
  "name": "heady-bee-factory",
  "version": "3.2.3",
  "type": "module",
  "description": "Dynamic bee creation \u2014 30+ bee types, concurrent-equal spawning",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "PORT=3320 node --watch index.js",
    "health": "curl -s http://localhost:3320/health | jq ."
  },
  "dependencies": {
    "express": "^4.21.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.0",
    "@opentelemetry/instrumentation-express": "^0.41.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "heady": {
    "domain": "agents",
    "port": 3320,
    "architecture": "concurrent-equals",
    "phiScaled": true,
    "autoContext": "mandatory"
  }
}