{
  "name": "heady-guard",
  "version": "3.2.3",
  "type": "module",
  "description": "Security enforcement \u2014 zero-trust validation, mTLS, IP classification",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "PORT=3330 node --watch index.js",
    "health": "curl -s http://localhost:3330/health | jq ."
  },
  "dependencies": {
    "express": "^4.21.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.0",
    "@opentelemetry/instrumentation-express": "^0.41.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "heady": {
    "domain": "security",
    "port": 3330,
    "architecture": "concurrent-equals",
    "phiScaled": true,
    "autoContext": "mandatory"
  }
}