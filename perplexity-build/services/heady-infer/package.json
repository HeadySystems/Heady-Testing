{
  "name": "heady-infer",
  "version": "3.2.3",
  "type": "module",
  "description": "Inference engine \u2014 model routing, streaming, evaluation",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "PORT=3314 node --watch index.js",
    "health": "curl -s http://localhost:3314/health | jq ."
  },
  "dependencies": {
    "express": "^5.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.0",
    "@opentelemetry/instrumentation-express": "^0.41.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "heady": {
    "domain": "inference",
    "port": 3314,
    "architecture": "concurrent-equals",
    "phiScaled": true,
    "autoContext": "mandatory"
  }
}