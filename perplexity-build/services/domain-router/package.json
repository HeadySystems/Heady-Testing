{
  "name": "domain-router",
  "version": "3.2.3",
  "type": "module",
  "description": "Domain-based routing \u2014 resolves all 9 sites + aliases to services",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "PORT=3373 node --watch index.js",
    "health": "curl -s http://localhost:3373/health | jq ."
  },
  "dependencies": {
    "express": "^4.21.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.0",
    "@opentelemetry/instrumentation-express": "^0.41.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "heady": {
    "domain": "integration",
    "port": 3373,
    "architecture": "concurrent-equals",
    "phiScaled": true,
    "autoContext": "mandatory"
  }
}