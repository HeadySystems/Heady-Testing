{
  "name": "heady-health",
  "version": "3.2.3",
  "type": "module",
  "description": "Health monitoring \u2014 \u03c6-interval probes, anomaly detection",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "PORT=3340 node --watch index.js",
    "health": "curl -s http://localhost:3340/health | jq ."
  },
  "dependencies": {
    "express": "^5.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.0",
    "@opentelemetry/instrumentation-express": "^0.41.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "heady": {
    "domain": "monitoring",
    "port": 3340,
    "architecture": "concurrent-equals",
    "phiScaled": true,
    "autoContext": "mandatory"
  }
}