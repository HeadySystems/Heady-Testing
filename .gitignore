# ══════════════════════════════════════════════════════════════
# SECURITY HARDENING — SEC-004 — 2026-02-27
# These patterns prevent ALL known sensitive file types from
# being committed. Generated by security audit.
# ══════════════════════════════════════════════════════════════

# Credentials / Secrets (defense-in-depth)
.env
.env.*
!.env.example
.env.hybrid
.env.production
.env.staging
.env.local
**/*.credentials
**/credentials.json
**/*-credentials.json
**/service-account.json
**/*secret*
!**/self-awareness.js
*.secret
**/.secrets/
**/secrets/

# PID files (process metadata leakage)
*.pid
server.pid
admin-ui.pid
.autoflow.pid
.headyai.pid
.headybuddy.pid
heady-manager.pid
python-worker.pid

# Backup files (deprecated code leakage)
*.bak
*.bak.*
*.backup-*
*.old
render.yaml.bak
.heady/registry.json.bak
heady-manager.js.bak

# Operational logs (metadata leakage)
*.jsonl
audit_logs*
.heady_deploy_log*
*.log
logs/
npm-debug.log*

# Private keys and certificates
*.key
*.pem
*.crt
*.p12
*.pfx
!configs/nginx/ssl/*.crt
!configs/nginx/ssl/*.key
!configs/nginx/ssl/*.pem

# ── Standard Ignores ──

# Node
node_modules/

# Build artifacts
build/
dist/
/coverage/
coverage/
.cache/
*.tgz

# Runtime data
/data/
data/
/tmp/

# IDE
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Temp files
*.temp
*.tmp
*~
test.txt

# Private architecture docs
.heady-private/

# Lock file conflict prevention (using npm)
# pnpm-lock.yaml

# Core dumps
core.*
core
heady-buddy/core.*

# ══════════════════════════════════════════════════════════════
# ADDITIONAL HARDENING — SEC-005 — 2026-03-01
# Patent evidence, deployment artifacts, database, terraform
# ══════════════════════════════════════════════════════════════

# Patent evidence snapshots (generated by CI/local)
patent-evidence-*.json
data/patent-evidence.jsonl

# Database dumps and state
*.sql
*.dump
*.sqlite
*.db

# Terraform / Infrastructure state
*.tfstate
*.tfstate.*
.terraform/

# Docker overrides (may contain secrets)
docker-compose.override.yml
docker-compose.*.local.yml

# Session / token files
*.session
*.token
.heady-session/


# Vector Vault encrypted secrets (NEVER commit)
data/vector-secrets-vault.enc
data/secrets-audit.jsonl

# Vault seed contains credentials — NEVER commit
scripts/vault-seed.js
heady-buddy/node_modules/
