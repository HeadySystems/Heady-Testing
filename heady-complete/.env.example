# ════════════════════════════════════════════════════════════
# Heady Latent OS — Environment Configuration
# Copy to .env and fill in values. REQUIRED vars must be set.
# ════════════════════════════════════════════════════════════

# ── Core ───────────────────────────────────────────────────
PORT=3301                           # REQUIRED
NODE_ENV=development                # REQUIRED — development | staging | production
LOG_LEVEL=info                      # debug | info | warn | error
CORS_ORIGINS=http://localhost:3301,https://headyme.com

# ── Authentication ─────────────────────────────────────────
JWT_SECRET=                         # REQUIRED — Generate: openssl rand -hex 32
SESSION_SECRET=                     # Generate: openssl rand -hex 32
GOOGLE_CLIENT_ID=                   # Google OAuth (for headyme.com dashboard)
GOOGLE_CLIENT_SECRET=

# ── AI Providers ───────────────────────────────────────────
ANTHROPIC_API_KEY=                  # Claude — console.anthropic.com
OPENAI_API_KEY=                     # GPT/Codex — platform.openai.com
GEMINI_API_KEY=                     # Gemini — aistudio.google.com
GROQ_API_KEY=                       # Groq — console.groq.com
PERPLEXITY_API_KEY=                 # Perplexity — perplexity.ai

# ── Local AI (Ollama) ─────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Embeddings ─────────────────────────────────────────────
EMBEDDINGS_PROVIDER=ollama          # REQUIRED — ollama | openai | vertex
EMBEDDINGS_MODEL=nomic-embed-text
EMBEDDINGS_DIMENSIONS=768

# ── Memory ─────────────────────────────────────────────────
MEMORY_STORE_PATH=./data/memory     # REQUIRED
MEMORY_MAX_ENTRIES=100000
CHECKPOINT_PATH=./data/checkpoints

# ── MCP Gateway ────────────────────────────────────────────
MCP_BEARER_TOKEN=                   # REQUIRED — Generate: openssl rand -hex 32
MCP_GATEWAY_URL=http://localhost:3301/mcp/v1
MCP_MAX_CONCURRENT=10

# ── Cloudflare ─────────────────────────────────────────────
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_TUNNEL_TOKEN=
CF_KV_NAMESPACE_ID=

# ── Google Cloud ───────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
VERTEX_AI_ENDPOINT=
GCS_BUCKET=

# ── GitHub ─────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_ORG=HeadyMe

# ── Notion ─────────────────────────────────────────────────
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── Auto-Success Engine ───────────────────────────────────
AUTO_SUCCESS_INTERVAL=30000
AUTO_SUCCESS_MAX_RETRIES=3
AUTO_SUCCESS_LEARNING_MODE=true

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Monitoring ─────────────────────────────────────────────
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=true
METRICS_PORT=9090
