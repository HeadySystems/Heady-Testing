# ═══════════════════════════════════════════════════════════════════
# Heady Systems — Environment Variable Template
# Copy to .env.hybrid and fill in your values.
# NEVER commit .env.hybrid to version control.
# ═══════════════════════════════════════════════════════════════════

# ─── Core ─────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3301
HEADY_PORT=3301
LOG_LEVEL=info

# ─── Auth & Admin ─────────────────────────────────────────────────
ADMIN_TOKEN=                           # Required: Admin API token
HEADY_ADMIN_TOKEN=                     # Required: Heady admin bearer token
HEADY_ADMIN_PASSWORD=                  # Required: Admin dashboard password
HEADY_API_KEY=                         # Required: Main API key

# ─── AI Providers (at least one required) ─────────────────────────
OPENAI_API_KEY=                        # OpenAI API key
OPENAI_MODEL=gpt-4o                    # Default OpenAI model
OPENAI_ORG_ID=                         # Optional: OpenAI org
ANTHROPIC_API_KEY=                     # Anthropic Claude API key
ANTHROPIC_ORG_ID=                      # Anthropic org ID
GEMINI_API_KEY_HEADY=                  # Google Gemini API key
GOOGLE_API_KEY=                        # Google AI platform key
GROQ_API_KEY=                          # Groq fast inference
PERPLEXITY_API_KEY=                    # Perplexity search API
CLAUDE_API_KEY=                        # Alternative Claude key

# ─── Google Cloud ─────────────────────────────────────────────────
GCLOUD_PROJECT_ID=                     # GCP project ID
GOOGLE_CLOUD_PROJECT=                  # GCP project (alt)
GCP_SA_KEY=                            # Service account JSON key (base64)
GOOGLE_APPLICATION_CREDENTIALS=        # Path to SA key file
GOOGLE_CLIENT_ID=                      # OAuth client ID
GOOGLE_CLIENT_SECRET=                  # OAuth client secret
GOOGLE_REDIRECT_URI=                   # OAuth redirect URI

# ─── Firebase ─────────────────────────────────────────────────────
FIREBASE_API_KEY=                      # Firebase web API key

# ─── Cloudflare ───────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=                 # Cloudflare account ID
CLOUDFLARE_API_TOKEN=                  # Cloudflare API token (Workers/DNS)
CF_VECTORIZE_INDEX=                    # Cloudflare Vectorize index name

# ─── GitHub ───────────────────────────────────────────────────────
GITHUB_TOKEN=                          # GitHub PAT for API access
GITHUB_APP_ID=                         # GitHub App ID
GITHUB_APP_INSTALLATION_ID=            # GitHub App installation ID
GITHUB_APP_PRIVATE_KEY=                # GitHub App private key (PEM)

# ─── Hugging Face ─────────────────────────────────────────────────
HF_TOKEN=                              # Primary HF inference token
HF_TOKEN_2=                            # Secondary HF token
HF_TOKEN_3=                            # Tertiary HF token

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379       # Redis connection URL

# ─── Vector Database ──────────────────────────────────────────────
QDRANT_URL=                            # Qdrant vector DB URL

# ─── Heady Service URLs ──────────────────────────────────────────
HEADY_MANAGER_URL=https://manager.headysystems.com
HEADY_EDGE_PROXY_URL=https://headysystems.com
HEADY_CLOUDRUN_URL=                    # Cloud Run service URL
HEADY_BRAIN_URL=                       # Brain service endpoint
HEADY_MCP_URL=                         # MCP server URL
HEADY_BOT_URL=                         # Bot service URL
HEADY_IO_URL=                          # HeadyIO URL
HEADY_CONNECTION_URL=                  # HeadyConnection URL

# ─── Notion ───────────────────────────────────────────────────────
NOTION_API_KEY=                        # Notion integration token
NOTION_TOKEN=                          # Notion API token (alt)

# ─── Payments (Stripe) ───────────────────────────────────────────
STRIPE_SECRET_KEY=                     # Stripe secret key
STRIPE_WEBHOOK_SECRET=                 # Stripe webhook signing secret
STRIPE_PRICE_PRO=                      # Stripe Pro plan price ID
STRIPE_PRICE_ENTERPRISE=               # Stripe Enterprise plan price ID

# ─── Web3 ─────────────────────────────────────────────────────────
WEB3_RPC_URL=                          # Ethereum RPC URL
WEB3_PRIVATE_KEY=                      # Web3 wallet private key
HEADY_ANCHOR_CONTRACT=                 # Smart contract address

# ─── MIDI / DAW ──────────────────────────────────────────────────
DAW_MCP_PORT=                          # DAW MCP bridge port
DAW_REMOTE_HOST=                       # Remote DAW host
DAW_REMOTE_PORT=                       # Remote DAW port
DAW_UDP_PORT=                          # DAW UDP transport port
UMP_LISTEN_PORT=                       # UMP MIDI listen port
UMP_SEND_HOST=                         # UMP MIDI send host
UMP_SEND_PORT=                         # UMP MIDI send port

# ─── Realtime Intelligence ───────────────────────────────────────
HEADY_REALTIME_API_ENDPOINT=           # Realtime API URL
HEADY_REALTIME_HTTPS_ENDPOINT=         # Realtime HTTPS URL
HEADY_REALTIME_MCP_ENDPOINT=           # Realtime MCP URL
HEADY_REALTIME_TCP_HOST=               # Realtime TCP host
HEADY_REALTIME_TCP_PORT=               # Realtime TCP port
HEADY_REALTIME_FLUSH_INTERVAL=5000     # Flush interval in ms
HEADY_REALTIME_MAX_QUEUE=1000          # Max queue size

# ─── Budget & Compute ────────────────────────────────────────────
HEADY_DAILY_BUDGET=10                  # Daily provider spend limit ($)
HEADY_COMPUTE_KEY=                     # Remote compute API key
HEADY_COLAB_WORKER_URL=                # Google Colab worker URL

# ─── AI Provider Keys (Secondary/Advanced) ───────────────────────
ANTHROPIC_SECONDARY_KEY=               # Secondary Anthropic key
ANTHROPIC_SECONDARY_ACCOUNT=           # Secondary Anthropic account
ANTHROPIC_ADMIN_KEY=                   # Anthropic admin key
ANTHROPIC_ACCOUNT=                     # Primary Anthropic account
GOOGLE_API_KEY_SECONDARY=              # Secondary Google key
HEADY_NEXUS_KEY=                       # HeadyNexus primary key
HEADY_NEXUS_KEY_SECONDARY=             # HeadyNexus secondary key
HEADY_PYTHIA_KEY_HEADY=                # Pythia key (heady)
HEADY_PYTHIA_KEY_GCLOUD=               # Pythia key (gcloud)
HEADY_PYTHIA_KEY_COLAB=                # Pythia key (colab)
HEADY_PYTHIA_KEY_STUDIO=               # Pythia key (studio)
HEADY_JULES_KEY=                       # HeadyJules key

# ─── Feature Flags ───────────────────────────────────────────────
OPENAI_CODEX_ENABLED=false             # Enable Codex integration
OPENAI_CONNECTORS_ENABLED=false        # Enable OpenAI connectors
OPENAI_BUSINESS_SEATS=1                # OpenAI business seat count
HEADY_CONTENT_FILTER=true              # Content filtering
PIPELINE_SIMULATION_MODE=false         # Pipeline dry-run mode
LENS_POLL_INTERVAL_MS=15000            # HeadyLens poll interval

# ─── Internal ────────────────────────────────────────────────────
INTERNAL_NODE_SECRET=                  # Inter-node auth secret
BRAIN_ENDPOINT=                        # Internal brain endpoint
EDGE_DIFFUSION_API=                    # Edge diffusion service
LITELLM_URL=                           # LiteLLM proxy URL
OLLAMA_PORT=11434                      # Local Ollama port
HEADY_LOCAL_HOST=localhost             # Local development host
DEV_HOST=localhost                     # Dev server host
HEADY_MEMORY_DB=                       # Memory database path
ALLOWED_ORIGINS=                       # CORS allowed origins (comma-sep)
LOG_REDACTION=true                     # Redact PII from logs
APEX_ACCOUNT_TIER=standard             # Apex trading tier
