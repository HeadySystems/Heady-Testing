{
    "name": "@heady-ai/template-mcp-server",
    "version": "1.0.0",
    "description": "Heady™ Model Context Protocol Server Template",
    "private": true,
    "scripts": {
        "start": "node src/index.js",
        "dev": "node --watch src/index.js",
        "docker:build": "docker build -t heady-mcp .",
        "docker:run": "docker run -p 8080:8080 heady-mcp"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.0",
        "hono": "^4.4.0",
        "dotenv": "^16.4.0"
    },
    "heady": {
        "template": "mcp-server",
        "transport": [
            "sse",
            "stdio"
        ],
        "deployTargets": [
            "cloud-run",
            "cloudflare-workers"
        ]
    }
}