{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@heady-ai/phi-math": ["packages/phi-math/src/index"],
      "@heady-ai/csl-router": ["packages/csl-router/src/index"],
      "@heady-ai/spatial-events": ["packages/spatial-events/src/index"],
      "@heady-ai/agent-identity": ["packages/agent-identity/src/index"],
      "@heady-ai/memory-stream": ["packages/memory-stream/src/index"],
      "@heady-ai/observability-kernel": ["packages/observability-kernel/src/index"],
      "@heady-ai/latent-boundary": ["packages/latent-boundary/src/index"],
      "@heady-ai/kernel": ["packages/kernel/src/index"]
    }
  }
}
