                  "pm.test('Response has message', () => {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data.message).to.have.property('content');",
                  "});",
                  "console.log('[Brain] Response:', pm.response.json().message?.content?.substring(0, 100));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/brain/chat",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a helpful AI assistant powered by HeadyOS.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"What is multi-agent orchestration and how does HeadyOS implement it?\"\n    }\n  ],\n  \"temperature\": 0.618,\n  \"maxTokens\": 1440\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Analyze",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/brain/analyze",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"input\": \"HeadyOS is a revolutionary multi-agent orchestration platform.\",\n  \"analysisType\": \"sentiment\",\n  \"outputFormat\": \"json\",\n  \"confidence\": true\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Chat with Agent",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/brain/chat",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messages\": [\n    { \"role\": \"user\", \"content\": \"Analyze the latest enterprise AI trends.\" }\n  ],\n  \"agentId\": \"{{agent_id}}\",\n  \"memoryNamespace\": \"{{memory_namespace}}\",\n  \"temperature\": 0.618\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Agents",
      "item": [
        {
          "name": "Create Agent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "if (data.id) {",
                  "  pm.environment.set('agent_id', data.id);",
                  "  console.log('[Agents] Created agent ID:', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/agents",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"research-agent\",\n  \"description\": \"Specialized research and analysis agent\",\n  \"systemPrompt\": \"You are a professional research analyst. Provide detailed, evidence-based analysis.\",\n  \"capabilities\": [\"mcp_tools\", \"memory_read\", \"memory_write\", \"web_search\"],\n  \"tools\": [\"web_search\", \"code_interpreter\"],\n  \"memoryNamespace\": \"research-context\",\n  \"maxIterations\": 13,\n  \"temperature\": 0.618\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "List Agents",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/agents?page=1&pageSize=13",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "13" }
              ]
            }
          }
        },
        {
          "name": "Get Agent",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/agents/{{agent_id}}"
          }
        },
        {
          "name": "Update Agent",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/agents/{{agent_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated research agent with broader capabilities\",\n  \"status\": \"active\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Agent",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/agents/{{agent_id}}"
          }
        }
      ]
    },
