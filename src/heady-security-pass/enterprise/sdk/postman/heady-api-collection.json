              "raw": "{\n  \"query\": \"multi-agent orchestration platform capabilities\",\n  \"namespace\": \"{{memory_namespace}}\",\n  \"topK\": 5,\n  \"minScore\": 0.382,\n  \"includeMetadata\": true\n}",
