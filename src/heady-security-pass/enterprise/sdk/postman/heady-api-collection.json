{
  "info": {
    "_postman_id": "heady-api-collection-v1",
    "name": "HeadyOS API Collection",
    "description": "Official Postman collection for the HeadyOS Platform API (headyme.com).\n\nHeadySystems Inc. (DBA Heady™)\n\n## Setup\n1. Import this collection into Postman\n2. Create an environment with:\n   - `base_url`: https://api.headyme.com/v1\n   - `api_key`: Your API key from headyme.com/settings/api-keys\n   - `tenant_id`: Your organization tenant ID (optional)\n3. Run 'Auth > Create Token' to populate the `access_token` variable automatically\n\n## φ (Golden Ratio) Defaults\nAll rate limits and numeric parameters derive from φ = 1.618033988749895 and Fibonacci sequences.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-refresh token if expired",
          "const tokenExpiry = pm.environment.get('token_expires_at');",
          "if (tokenExpiry && new Date(tokenExpiry) < new Date()) {",
          "  console.log('[HeadyOS] Token expired — refreshing...');",
          "  const refreshToken = pm.environment.get('refresh_token');",
          "  if (refreshToken) {",
          "    pm.sendRequest({",
          "      url: pm.environment.get('base_url') + '/auth/token/refresh',",
          "      method: 'POST',",
          "      header: { 'Content-Type': 'application/json' },",
          "      body: { mode: 'raw', raw: JSON.stringify({ refreshToken }) }",
          "    }, (err, res) => {",
          "      if (!err && res.code === 200) {",
          "        const data = res.json();",
          "        pm.environment.set('access_token', data.accessToken);",
          "        pm.environment.set('token_expires_at', data.expiresAt);",
          "        if (data.refreshToken) pm.environment.set('refresh_token', data.refreshToken);",
          "        console.log('[HeadyOS] Token refreshed successfully');",
          "      }",
          "    });",
          "  }",
          "}",
          "",
          "// Inject X-Heady-Tenant header if tenant_id set",
          "const tenantId = pm.environment.get('tenant_id');",
          "if (tenantId) {",
          "  pm.request.headers.add({ key: 'X-Heady-Tenant', value: tenantId });",
          "}",
          "",
          "// Generate request ID",
          "pm.request.headers.add({",
          "  key: 'X-Heady-Request-Id',",
          "  value: 'postman-' + Date.now() + '-' + Math.random().toString(36).slice(2,9)",
          "});"
        ]
      }
    }
  ],
  "variable": [
    { "key": "base_url", "value": "https://api.headyme.com/v1", "type": "string" },
    { "key": "api_key", "value": "", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "token_expires_at", "value": "", "type": "string" },
    { "key": "tenant_id", "value": "", "type": "string" },
    { "key": "agent_id", "value": "", "type": "string" },
    { "key": "task_id", "value": "", "type": "string" },
    { "key": "memory_key", "value": "test-memory", "type": "string" },
    { "key": "memory_namespace", "value": "default", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Service is healthy', () => {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data.status).to.equal('healthy');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Detailed Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health/detailed"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Create Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "if (data.accessToken) {",
                  "  pm.environment.set('access_token', data.accessToken);",
                  "  pm.environment.set('refresh_token', data.refreshToken);",
                  "  pm.environment.set('token_expires_at', data.expiresAt);",
                  "  console.log('[HeadyOS] Token stored. Expires:', data.expiresAt);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/auth/token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"apiKey\": \"{{api_key}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.accessToken) {",
                  "  pm.environment.set('access_token', data.accessToken);",
                  "  pm.environment.set('token_expires_at', data.expiresAt);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/auth/token/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "List API Keys",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/keys"
          }
        },
        {
          "name": "Create API Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.key) {",
                  "  console.log('NEW API KEY (save this — shown only once!):', data.key);",
                  "  pm.environment.set('api_key', data.key);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/keys",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My API Key\",\n  \"scopes\": [\"brain:read\", \"agents:write\", \"memory:write\"]\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Brain",
      "item": [
        {
          "name": "Chat",
          "event": [
