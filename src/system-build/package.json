{
  "name": "heady-system-build",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "docker compose up --build",
    "build": "npm run build:services && npm run build:sites",
    "start": "docker compose up --build",
    "lint": "node scripts/compliance-check.mjs",
    "build:sites": "python build-sites.py",
    "build:services": "python scripts/gen-services.py",
    "health:all": "node scripts/health-check-all.mjs",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down --remove-orphans",
    "test": "node --test tests/*.test.js",
    "test:ci": "npm run build:services && npm run lint && npm run test",
    "validate": "npm run lint && npm run test"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
