  "panels": [
    {
      "title": "Service Health Overview",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "count(up{job='heady-services'} == 1)",
          "legendFormat": "Healthy"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 55
              }
            ]
          }
        }
      }
    },
    {
      "title": "Total Request Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job='heady-services'}[5m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "title": "P99 Latency by Service",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job='heady-services'}[5m])) by (le, service))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "title": "Error Rate by Service",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job='heady-services',status=~'5..'}[5m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "title": "Coherence Score",
      "type": "gauge",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "avg(heady_coherence_score)",
          "legendFormat": "coherence"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.691
              },
              {
                "color": "green",
                "value": 0.809
              }
            ]
          }
        }
      }
    },
    {
      "title": "Circuit Breaker States",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "heady_circuit_breaker_state",
          "legendFormat": "{{service}}",
          "format": "table",
          "instant": true
        }
      ]
    }
  ],
