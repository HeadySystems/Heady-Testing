{
  "name": "@heady-ai/migration-service",
  "version": "2.0.0",
  "type": "module",
  "description": "Schema migration service with φ-scaled versioning and CSL-gated rollback safety",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "migrate:up": "node src/index.js --direction=up",
    "migrate:down": "node src/index.js --direction=down",
    "migrate:status": "node src/index.js --status"
  },
  "dependencies": {
    "@heady-ai/phi-math-foundation": "workspace:*",
    "@heady-ai/structured-logger": "workspace:*"
  }
}
