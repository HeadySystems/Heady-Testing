# Search Service Environment
HEADY_ENV=production
PORT=8089
PG_CONNECTION_STRING=postgresql://heady:${PG_PASSWORD}@pg-primary.heady-internal:5432/heady_vectors
NATS_URL=nats://nats.heady-internal:4222
EMBEDDING_PROVIDER=nomic
EMBEDDING_MODEL=nomic-embed-text-v1.5
EMBEDDING_DIMENSIONS=384
SEARCH_TIMEOUT_MS=4236
MAX_RESULTS_DEFAULT=21
RERANK_TOP_K=21
HYBRID_RRF_K=55
CSL_RELEVANCE_THRESHOLD=0.691
