{
  "dashboard": {
    "title": "Heady™ System Overview — Sacred Geometry Metrics",
    "uid": "heady-overview",
    "timezone": "browser",
    "refresh": "34s",
    "time": { "from": "now-89m", "to": "now" },
    "annotations": { "list": [] },
    "panels": [
      {
        "id": 1,
        "title": "System Coherence Score",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
        "targets": [{
          "expr": "avg(heady_coherence_score)",
          "legendFormat": "Coherence"
        }],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 0.500, "color": "orange" },
                { "value": 0.691, "color": "yellow" },
                { "value": 0.809, "color": "green" },
                { "value": 0.927, "color": "blue" }
              ]
            },
            "min": 0, "max": 1
          }
        }
      },
      {
        "id": 2,
        "title": "Mesh Pressure",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
        "targets": [{
          "expr": "heady_mesh_pressure",
          "legendFormat": "Pressure"
        }],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 0.382, "color": "yellow" },
                { "value": 0.618, "color": "orange" },
                { "value": 0.854, "color": "red" }
              ]
            },
            "min": 0, "max": 1
          }
        }
      },
      {
        "id": 3,
        "title": "Active Services",
        "type": "stat",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
        "targets": [{
          "expr": "count(up == 1)",
          "legendFormat": "Active"
        }]
      },
      {
        "id": 4,
        "title": "Request Latency (p95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          { "expr": "histogram_quantile(0.95, heady_request_duration_seconds_bucket{pool=\"HOT\"})", "legendFormat": "HOT p95" },
          { "expr": "histogram_quantile(0.95, heady_request_duration_seconds_bucket{pool=\"WARM\"})", "legendFormat": "WARM p95" },
          { "expr": "histogram_quantile(0.95, heady_request_duration_seconds_bucket{pool=\"COLD\"})", "legendFormat": "COLD p95" }
        ]
      },
      {
        "id": 5,
        "title": "Pool Resource Allocation",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          { "expr": "0.34", "legendFormat": "HOT (34%)" },
          { "expr": "0.21", "legendFormat": "WARM (21%)" },
          { "expr": "0.13", "legendFormat": "COLD (13%)" },
          { "expr": "0.08", "legendFormat": "Reserve (8%)" },
          { "expr": "0.05", "legendFormat": "Governance (5%)" }
        ]
      },
      {
        "id": 6,
        "title": "Pipeline Throughput",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [{
          "expr": "rate(heady_pipeline_completed_total[5m])",
          "legendFormat": "Pipelines/s"
        }]
      },
      {
        "id": 7,
        "title": "Bee Swarm Status",
        "type": "bargauge",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          { "expr": "heady_swarm_bees_total{state=\"READY\"}", "legendFormat": "Ready" },
          { "expr": "heady_swarm_bees_total{state=\"WORKING\"}", "legendFormat": "Working" },
          { "expr": "heady_swarm_bees_total{state=\"DRAINING\"}", "legendFormat": "Draining" }
        ]
      },
      {
        "id": 8,
        "title": "Colab Runtime Health",
        "type": "table",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
        "targets": [{
          "expr": "heady_colab_runtime_status",
          "legendFormat": "{{runtime}}"
        }]
      },
      {
        "id": 9,
        "title": "Vector Memory Index Size",
        "type": "stat",
        "gridPos": { "h": 4, "w": 8, "x": 0, "y": 32 },
        "targets": [{ "expr": "heady_vector_index_size", "legendFormat": "Vectors" }]
      },
      {
        "id": 10,
        "title": "Cache Hit Rate",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 8, "x": 8, "y": 32 },
        "targets": [{ "expr": "heady_cache_hit_rate", "legendFormat": "Hit Rate" }],
        "fieldConfig": { "defaults": { "min": 0, "max": 1 } }
      },
      {
        "id": 11,
        "title": "Error Rate",
        "type": "timeseries",
        "gridPos": { "h": 4, "w": 8, "x": 16, "y": 32 },
        "targets": [{ "expr": "rate(heady_errors_total[5m])", "legendFormat": "Errors/s" }]
      }
    ]
  }
}
