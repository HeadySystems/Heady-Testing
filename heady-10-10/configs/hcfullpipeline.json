        "maxRetries": 3,
        "baseMs": 1000,
        "multiplier": 1.618,
        "sequence": [1000, 1618, 2618]
      },
      "skipIfOptional": true,
      "haltIfRequired": true,
      "notifyNode": "HeadyGuard"
