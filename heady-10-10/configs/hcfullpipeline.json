    "onStepFailure": {
      "strategy": "retry-then-fail-stage",
      "retryPolicy": {
        "maxRetries": 3,
        "baseMs": 1000,
        "multiplier": 1.618,
        "sequence": [1000, 1618, 2618]
      },
      "failFastOverride": true,
      "captureError": true,
      "notifyNode": "HeadyHealth"
    },
    "onGovernanceDeny": {
      "strategy": "halt-and-report",
