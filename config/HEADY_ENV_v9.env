# ─── CORE ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
HEADY_VERSION=4.0.0
HEADY_SERVICE=heady-manager
HEADY_ROLE=primary
HEADY_LOG_LEVEL=info
HEADY_LOG_FORMAT=json

# ─── §1  UPSTASH REDIS (T0 Working Memory) ──────────────────────────────────
UPSTASH_REDIS_REST_URL=https://usw2-YOUR-INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...your-token
QSTASH_TOKEN=eyJ...your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=sig_...
QSTASH_NEXT_SIGNING_KEY=sig_...

# ─── §2  NEON POSTGRES (T1 Persistent Memory) ───────────────────────────────
DATABASE_URL=postgresql://heady:PASSWORD@ep-cold-snow-aesmiwt9.us-east-2.aws.neon.tech/neondb?sslmode=require
NEON_DATABASE_URL=${DATABASE_URL}
NEON_HOST=ep-cold-snow-aesmiwt9.us-east-2.aws.neon.tech
NEON_USER=heady
NEON_PASSWORD=
NEON_DATABASE=neondb
NEON_PORT=5432
NEON_SSL=require
NEON_API_KEY=
PG_POOL_SIZE=10
PG_IDLE_TIMEOUT=10000
PG_CONNECT_TIMEOUT=5000
PG_STATEMENT_TIMEOUT=30000

# pgvector tuning
VECTOR_DIMENSIONS=1536
VECTOR_INDEX_TYPE=hnsw
HNSW_M=16
HNSW_EF_CONSTRUCTION=64
HNSW_EF_SEARCH=40

# ─── §3  CLOUDFLARE (Edge Layer) ────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=8b1fa38f282c691423c6399247d53323
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
HEADY_CLOUDFLARE_AI_GATEWAY=heady-gateway
HYPERDRIVE_ID=

# Domain tunnel IDs
HEADY_TUNNEL_ID_HEADYSYSTEMS=
HEADY_TUNNEL_ID_HEADYME=
HEADY_TUNNEL_ID_HEADYBUDDY=
HEADY_TUNNEL_ID_HEADYMCP=
HEADY_TUNNEL_ID_HEADYIO=
HEADY_TUNNEL_ID_HEADYBOT=
HEADY_TUNNEL_ID_HEADYAPI=
HEADY_TUNNEL_ID_HEADYCONNECTION=
HEADY_TUNNEL_ID_HEADYAI=

# ─── §4  GCP (Cloud Run + Gemini) ───────────────────────────────────────────
GCP_PROJECT_ID=headyme-444017
GCP_REGION=us-central1
CLOUD_RUN_URL=https://headyme-site-667608982461.us-central1.run.app
GOOGLE_AI_API_KEY=
GOOGLE_CLOUD_PROJECT=${GCP_PROJECT_ID}
GOOGLE_APPLICATION_CREDENTIALS=

# Firebase
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=headyme-444017.firebaseapp.com
FIREBASE_PROJECT_ID=headyme-444017
FIREBASE_STORAGE_BUCKET=headyme-444017.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=667608982461
FIREBASE_APP_ID=

# ─── §5  AZURE (OpenAI + Cosmos DB) ─────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443
COSMOS_KEY=
COSMOS_DATABASE=heady-state

# ─── §6  HUGGINGFACE (Models + Inference) ───────────────────────────────────
# 3-token round-robin rotation per v9.0 blueprint
HF_TOKEN=hf_...your-primary-token
HF_TOKEN_1=${HF_TOKEN}
HF_TOKEN_2=hf_...second-token
HF_TOKEN_3=hf_...third-token
HF_HOME=/tmp/huggingface

# ─── §7  GITHUB CI / CD ─────────────────────────────────────────────────────
GITHUB_TOKEN=
HEADY_REPO=EricHaywood/Heady
# Turborepo remote caching handled by turbo-ci.yml

# ─── §8  SENTRY (Observability) ─────────────────────────────────────────────
SENTRY_DSN=https://1b34e12c988678f066c6948a31d43ff0@o4510998791192576.ingest.us.sentry.io/4510998806069248
SENTRY_AUTH_TOKEN=
SENTRY_RELEASE=heady-manager@${HEADY_VERSION}
SENTRY_ENABLED=true

# ─── §9  COLAB PRO+ (GPU Runtimes) ──────────────────────────────────────────
# Alpha: Training (A100)
# Beta:  Evaluation (L4)
# Gamma: Serving/vLLM (L4)
# Delta: DSPy/LoRA optimization (A100)
COLAB_RUNTIME_ALPHA=
COLAB_RUNTIME_BETA=
COLAB_RUNTIME_GAMMA=
COLAB_RUNTIME_DELTA=

# ─── §10  RUNTIME DELTA (Self-Improvement) ──────────────────────────────────
JUDGE_MODEL=gemini-2.5-flash-lite
ROUTING_MODEL=gpt-5-nano
PRODUCTION_GATE_THRESHOLD=0.05
MONTHLY_BUDGET_USD=750

# ─── AUTH & SESSIONS ─────────────────────────────────────────────────────────
JWT_SECRET=
HEADY_JWT_SECRET=${JWT_SECRET}
HEADY_SESSION_SECRET=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://auth.headysystems.com/callback

# ─── OPENAI (Direct — non-Azure fallback) ───────────────────────────────────
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_MODEL=gpt-4.1-mini

# ─── ANTHROPIC ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── PERPLEXITY ──────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=

# ─── DISCORD ─────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# ─── STRIPE (Billing) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ─── EMAIL (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
RESEND_API_KEY=

# ─── HEADY SERVICE URLS ─────────────────────────────────────────────────────
HEADY_URL=https://headysystems.com
HEADY_ME_URL=https://headyme.com
HEADY_SYSTEMS_URL=https://headysystems.com
HEADY_MCP_URL=https://headymcp.com
HEADY_IO_URL=https://headyio.com
HEADY_MANAGER_URL=${CLOUD_RUN_URL}
HEADY_GUARD_URL=https://guard.headysystems.com
HEADY_INFER_URL=https://infer.headysystems.com
HEADY_VECTOR_URL=https://vector.headysystems.com
HEADY_STREAM_URL=https://stream.headysystems.com
HEADY_SWARM_URL=https://swarm.headysystems.com
HEADY_SIMS_URL=https://sims.headysystems.com

# ─── OBSERVABILITY (OpenTelemetry) ──────────────────────────────────────────
OTEL_SERVICE_NAME=heady-manager
OTEL_SERVICE_VERSION=${HEADY_VERSION}
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_DEPLOYMENT_ENV=${NODE_ENV}
OTEL_SDK_DISABLED=false

# ─── HEALTH & MONITORING ────────────────────────────────────────────────────
HEALTH_CHECK_INTERVAL=30000
HEARTBEAT_INTERVAL=29034
HEALTH_SCORE_DEGRADED=80
HEALTH_SCORE_CRITICAL=50
HEALTH_WEBHOOK_URL=

# ─── SECURITY ────────────────────────────────────────────────────────────────
HEADY_VAULT_KEY=
HEADY_VAULT_PASSPHRASE=
INTERNAL_API_KEY=
TRUST_PROXY=true
MTLS_ENABLED=false

# ─── HEADY GUARD (Content Safety) ───────────────────────────────────────────
HEADY_GUARD_RATE_RPM=60
HEADY_GUARD_RATE_RPH=1000
HEADY_GUARD_PIPELINE_TIMEOUT_MS=30000
HEADY_GUARD_LOG_LEVEL=info

###############################################################################
#  END — Liquid Architecture v9.0 Master Environment
