# Heady Pilot Environment Configuration - CORRECTED
# Updated: March 7, 2026 12:34 PM MST
# Purpose: 100% Pilot-Ready Configuration with Owned Domains

# ============================================================
# CORE SERVICE URLs (Using Actual Owned Domains)
# ============================================================

# API Gateway - PRIMARY ENDPOINT
HEADY_API_URL=https://api.headyapi.com
HEADY_API_PILOT_URL=https://pilot.headyapi.com
HEADY_API_GATEWAY_URL=https://gateway.headyapi.com

# User-Facing Applications
HEADY_WEB_URL=https://headyme.com
HEADY_PILOT_URL=https://pilot.headyme.com
HEADY_DASHBOARD_URL=https://dashboard.headyme.com
HEADY_BUDDY_URL=https://headybuddy.org

# Infrastructure Services
HEADY_CLOUD_URL=https://headycloud.com
HEADY_CLOUD_CONSOLE_URL=https://console.headycloud.com
HEADY_CLOUD_DEPLOY_URL=https://deploy.headycloud.com
HEADY_CLOUD_ORCHESTRATOR_URL=https://orchestrator.headycloud.com

# Developer Platform
HEADY_IO_URL=https://headyio.com
HEADY_IO_DOCS_URL=https://docs.headyio.com
HEADY_IO_SANDBOX_URL=https://sandbox.headyio.com
HEADY_IO_API_URL=https://api.headyio.com

# AI Services
HEADY_AI_URL=https://headyai.com
HEADY_AI_ROUTER_URL=https://router.headyai.com
HEADY_AI_MODELS_URL=https://models.headyai.com
HEADY_AI_INFERENCE_URL=https://inference.headyai.com

# OS Layer
HEADY_OS_URL=https://headyos.com
HEADY_OS_KERNEL_URL=https://kernel.headyos.com
HEADY_OS_RUNTIME_URL=https://runtime.headyos.com
HEADY_OS_SCHEDULER_URL=https://scheduler.headyos.com

# MCP Protocol
HEADY_MCP_URL=https://headymcp.com
HEADY_MCP_SERVER_URL=https://server.headymcp.com

# Systems Hub
HEADY_SYSTEMS_URL=https://headysystems.com
HEADY_SYSTEMS_STATUS_URL=https://status.headysystems.com

# Community/Nonprofit
HEADY_CONNECTION_URL=https://headyconnection.org
HEADY_CONNECTION_COMMUNITY_URL=https://community.headyconnection.org

# Automation
HEADY_BOT_URL=https://headybot.com

# ============================================================
# AUTHENTICATION & SECURITY
# ============================================================

AUTH_PROVIDER=google,huggingface,facebook
AUTH_CALLBACK_URL=https://headyme.com/auth/callback
AUTH_SUCCESS_REDIRECT=/onboarding
AUTH_ERROR_REDIRECT=/auth/error

# Facebook / Meta (Heady-AI Meta App)
FACEBOOK_APP_ID=${FB_APP_ID}
FACEBOOK_APP_SECRET=${FB_APP_SECRET}
FACEBOOK_PAGE_ACCESS_TOKEN=${FB_PAGE_TOKEN}

JWT_SECRET=${PILOT_JWT_SECRET}
JWT_ISSUER=headyapi.com
JWT_AUDIENCE=headyme.com,headyio.com,headybuddy.org,headycloud.com
JWT_EXPIRATION=3600

SESSION_TIMEOUT=3600
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

CORS_ALLOWED_ORIGINS=https://headyme.com,https://headyio.com,https://headybuddy.org,https://headycloud.com,https://headyai.com,https://headyos.com

# ============================================================
# DATABASE & REDIS
# ============================================================

DATABASE_URL=postgresql://heady:pilot@db-pilot.heady.internal:5432/heady_pilot
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL_MODE=require

REDIS_URL=redis://redis-pilot.heady.internal:6379
REDIS_POOL_SIZE=10
REDIS_TTL_DEFAULT=3600

# ============================================================
# CLOUD INFRASTRUCTURE
# ============================================================

AWS_REGION=us-west-2
AWS_ACCOUNT_ID=${AWS_ACCOUNT}

CLOUDFLARE_ZONE_ID=${CF_ZONE}
CLOUDFLARE_ACCOUNT_ID=${CF_ACCOUNT}
CLOUDFLARE_API_TOKEN=${CF_API_TOKEN}

RENDER_SERVICE_ID=${RENDER_ID}
RENDER_API_KEY=${RENDER_KEY}

# ============================================================
# FEATURE FLAGS
# ============================================================

PILOT_MODE=true
ONBOARDING_V2=true
MONTE_CARLO_ORCHESTRATION=true
MULTI_AGENT_ENABLED=true
CONTEXT_SWITCHER_UI=true
AUTO_SUCCESS_ENGINE=true
LIQUID_ARCHITECTURE=true
ARENA_MODE=true
PHI_MATH_FOUNDATION=true

# ============================================================
# RATE LIMITING
# ============================================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_BURST=200

# API Key Tier Limits
RATE_LIMIT_FREE_TIER=100
RATE_LIMIT_PRO_TIER=1000
RATE_LIMIT_ENTERPRISE_TIER=10000

# ============================================================
# MONITORING & OBSERVABILITY
# ============================================================

SENTRY_DSN=${SENTRY_DSN}
SENTRY_ENVIRONMENT=pilot
SENTRY_SAMPLE_RATE=1.0

DATADOG_API_KEY=${DD_KEY}
DATADOG_SITE=datadoghq.com

HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_ENDPOINT=/health
METRICS_ENDPOINT=/metrics
READINESS_ENDPOINT=/ready

# ============================================================
# MCP CONFIGURATION
# ============================================================

MCP_ENABLED=true
MCP_MAX_TOOLS=50
MCP_TIMEOUT_MS=30000
MCP_RETRY_ATTEMPTS=3
MCP_SERVER_HOST=server.headymcp.com
MCP_SERVER_PORT=443
MCP_SERVER_PROTOCOL=https

# ============================================================
# AI MODEL ROUTING (headyai.com)
# ============================================================

AI_ROUTER_ENABLED=true
AI_ROUTER_URL=https://router.headyai.com

# Provider Configuration
AI_PROVIDER_ANTHROPIC_ENABLED=true
AI_PROVIDER_ANTHROPIC_MODELS=claude-opus-4-6,claude-sonnet-4-5
AI_PROVIDER_ANTHROPIC_KEY=${ANTHROPIC_KEY}

AI_PROVIDER_OPENAI_ENABLED=true
AI_PROVIDER_OPENAI_MODELS=gpt-5-4-turbo,o1
AI_PROVIDER_OPENAI_KEY=${OPENAI_KEY}

AI_PROVIDER_GOOGLE_ENABLED=true
AI_PROVIDER_GOOGLE_MODELS=gemini-3-1-pro,gemini-3-1-flash
AI_PROVIDER_GOOGLE_KEY=${GOOGLE_KEY}

AI_PROVIDER_PERPLEXITY_ENABLED=true
AI_PROVIDER_PERPLEXITY_MODELS=sonar-deep-research
AI_PROVIDER_PERPLEXITY_KEY=${PERPLEXITY_KEY}

AI_PROVIDER_GROQ_ENABLED=true
AI_PROVIDER_GROQ_MODELS=llama-3-3-70b
AI_PROVIDER_GROQ_KEY=${GROQ_KEY}

# Routing Strategy
AI_FALLBACK_STRATEGY=cascade
AI_LOAD_BALANCER=round-robin
AI_RETRY_ON_FAILURE=true
AI_MAX_RETRIES=3

# ============================================================
# CLOUD ORCHESTRATION (headycloud.com)
# ============================================================

CLOUD_ORCHESTRATOR_URL=https://orchestrator.headycloud.com
CLOUD_DEPLOY_PIPELINE_URL=https://pipeline.headycloud.com
CLOUD_MONITORING_URL=https://monitor.headycloud.com
CLOUD_LOGS_URL=https://logs.headycloud.com

# ============================================================
# OS RUNTIME (headyos.com)
# ============================================================

OS_KERNEL_URL=https://kernel.headyos.com
OS_SCHEDULER_URL=https://scheduler.headyos.com
OS_MEMORY_URL=https://memory.headyos.com
OS_RUNTIME_URL=https://runtime.headyos.com

# ============================================================
# AUTO-SUCCESS ENGINE
# ============================================================

AUTO_SUCCESS_ENABLED=true
AUTO_SUCCESS_INTERVAL_MS=30000
AUTO_SUCCESS_TASK_COUNT=135
AUTO_SUCCESS_CATEGORY_COUNT=9
AUTO_SUCCESS_TREAT_ERRORS_AS_LEARNING=true

# ============================================================
# LIQUID ARCHITECTURE
# ============================================================

LIQUID_ARCH_ENABLED=true
LIQUID_ARCH_SCALE_UP_THRESHOLD=0.8
LIQUID_ARCH_SCALE_DOWN_THRESHOLD=0.3
LIQUID_ARCH_MIN_REPLICAS=1
LIQUID_ARCH_MAX_REPLICAS=10
