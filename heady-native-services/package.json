{
  "name": "heady-native-services",
  "version": "1.0.0",
  "description": "Heady-native replacements for external AI provider dependencies — Sacred Geometry Architecture",
  "author": "HeadySystems Inc.",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node src/gateway.js",
    "start:embed": "node src/services/heady-embed/server.js",
    "start:infer": "node src/services/heady-infer/server.js",
    "start:vector": "node src/services/heady-vector/server.js",
    "start:chain": "node src/services/heady-chain/server.js",
    "start:cache": "node src/services/heady-cache/server.js",
    "start:guard": "node src/services/heady-guard/server.js",
    "start:eval": "node src/services/heady-eval/server.js",
    "test": "jest --runInBand",
    "test:embed": "jest src/services/heady-embed",
    "test:infer": "jest src/services/heady-infer",
    "test:vector": "jest src/services/heady-vector",
    "test:chain": "jest src/services/heady-chain",
    "test:cache": "jest src/services/heady-cache",
    "test:guard": "jest src/services/heady-guard",
    "test:eval": "jest src/services/heady-eval",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "health": "node scripts/health-check.js",
    "migrate": "node scripts/migrate.js"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.0",
    "axios": "^1.7.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "pg": "^8.12.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/__tests__/**"
    ]
  }
}
