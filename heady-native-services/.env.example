# HeadyNativeServices — Environment Configuration
# Sacred Geometry Architecture v3.0.0
# Copy to .env and fill in your values

# ─── Gateway ────────────────────────────────────────────────
HEADY_GATEWAY_PORT=3100
NODE_ENV=production

# ─── HeadyEmbed — Local Transformer Embeddings ─────────────
HEADY_EMBED_PORT=3101
HEADY_EMBED_MODEL=Xenova/all-MiniLM-L6-v2
HEADY_EMBED_BATCH_SIZE=32
HEADY_EMBED_CACHE_SIZE=10000
HEADY_EMBED_CACHE_TTL=86400000
HEADY_EMBED_DIMENSIONS=384

# ─── HeadyInfer — Multi-Model Inference Gateway ────────────
HEADY_INFER_PORT=3102
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_API_KEY=xxx
GROQ_API_KEY=gsk_xxx
OLLAMA_BASE_URL=http://localhost:11434

# Budget caps (USD per day)
HEADY_INFER_BUDGET_ANTHROPIC=50
HEADY_INFER_BUDGET_OPENAI=50
HEADY_INFER_BUDGET_GOOGLE=25
HEADY_INFER_BUDGET_GROQ=10
HEADY_INFER_BUDGET_GLOBAL_MONTHLY=1000

# ─── HeadyVector — pgvector Search Service ──────────────────
HEADY_VECTOR_PORT=3103
DATABASE_URL=postgresql://heady:heady_sacred_geometry@localhost:5432/heady
PG_POOL_SIZE=20
HNSW_M=16
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=100

# ─── HeadyChain — Agent Orchestration ───────────────────────
HEADY_CHAIN_PORT=3104
HEADY_CHAIN_MAX_STEPS=50
HEADY_CHAIN_TIMEOUT=300000
HEADY_INFER_URL=http://localhost:3102
HEADY_VECTOR_URL=http://localhost:3103
HEADY_EMBED_URL=http://localhost:3101

# ─── HeadyCache — Semantic Cache ────────────────────────────
HEADY_CACHE_PORT=3105
HEADY_CACHE_BACKEND=memory
HEADY_CACHE_MAX_SIZE=50000
HEADY_CACHE_TTL=3600000
HEADY_CACHE_SIMILARITY_THRESHOLD=0.95

# ─── HeadyGuard — Prompt Security ──────────────────────────
HEADY_GUARD_PORT=3106
HEADY_GUARD_BLOCK_THRESHOLD=80
HEADY_GUARD_FLAG_THRESHOLD=50
HEADY_GUARD_PII_MODE=redact
HEADY_GUARD_STAGES=injection,pii,toxicity,topic,rate_limit,output

# ─── HeadyEval — Evaluation Framework ──────────────────────
HEADY_EVAL_PORT=3107
HEADY_EVAL_JUDGE_MODEL=claude-3.5-sonnet
HEADY_EVAL_CONCURRENCY=5
HEADY_EVAL_DEFAULT_SCORERS=relevance,faithfulness,safety,coherence,helpfulness

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_PASSWORD=heady_sacred_geometry
