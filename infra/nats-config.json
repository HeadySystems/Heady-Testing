{
  "$schema": "https://docs.nats.io/schemas/jetstream-config",
  "_comment": "Heady™ Platform — NATS JetStream Configuration. All streams are concurrent equals. φ-derived constants. © 2024-2026 HeadySystems Inc.",
  "streams": [
    {
      "name": "HEADY_MEMORY",
      "subjects": ["heady.memory.>"],
      "description": "Vector operations: store, retrieve, update, delete embeddings (384-dim)",
      "retention": "limits",
      "max_consumers": -1,
      "max_msgs": 233,
      "max_bytes": 104857600,
      "max_age": 7776000000000000,
      "max_msg_size": 1048576,
      "storage": "file",
      "num_replicas": 1,
      "discard": "old",
      "duplicate_window": 89000000000
    },
    {
      "name": "HEADY_INFERENCE",
      "subjects": ["heady.inference.>"],
      "description": "Model inference requests and responses across all AI gateways",
      "retention": "limits",
      "max_consumers": -1,
      "max_msgs": 377,
      "max_bytes": 209715200,
      "max_age": 3888000000000000,
      "max_msg_size": 2097152,
      "storage": "file",
      "num_replicas": 1,
      "discard": "old",
      "duplicate_window": 55000000000
    },
    {
      "name": "HEADY_AGENTS",
      "subjects": ["heady.agents.>"],
      "description": "Bee swarm coordination: dispatch, result, status, heartbeat",
      "retention": "limits",
      "max_consumers": -1,
      "max_msgs": 610,
      "max_bytes": 104857600,
      "max_age": 1296000000000000,
      "max_msg_size": 524288,
      "storage": "file",
      "num_replicas": 1,
      "discard": "old",
      "duplicate_window": 34000000000
    },
    {
      "name": "HEADY_NOTIFICATIONS",
      "subjects": ["heady.notifications.>"],
      "description": "Real-time notification events: send, delivered, read, dismissed",
      "retention": "limits",
      "max_consumers": -1,
      "max_msgs": 987,
      "max_bytes": 52428800,
      "max_age": 604800000000000,
      "max_msg_size": 262144,
      "storage": "file",
      "num_replicas": 1,
      "discard": "old",
      "duplicate_window": 21000000000
    },
    {
      "name": "HEADY_DLQ",
      "subjects": ["heady.dlq.>"],
      "description": "Dead Letter Queue — messages that failed after φ³ (4) retries",
      "retention": "limits",
      "max_consumers": -1,
      "max_msgs": 1597,
      "max_bytes": 524288000,
      "max_age": 2592000000000000,
      "max_msg_size": 2097152,
      "storage": "file",
      "num_replicas": 1,
      "discard": "old",
      "duplicate_window": 89000000000
    }
  ],
  "consumers": {
    "_comment": "Default consumer configuration — per-stream consumers inherit these settings",
    "defaults": {
      "ack_policy": "explicit",
      "ack_wait": 34000000000,
      "max_deliver": 4,
      "max_ack_pending": 55,
      "deliver_policy": "all",
      "replay_policy": "instant"
    },
    "dlq_policy": {
      "_comment": "After φ³ ≈ 4.236 → 4 retries, move to HEADY_DLQ stream",
      "max_deliver": 4,
      "backoff": [5000000000, 8000000000, 13000000000, 21000000000],
      "dead_letter_subject_prefix": "heady.dlq"
    }
  }
}
