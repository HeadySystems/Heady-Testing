# Heady™ Service Dockerfile — Multi-stage build
# © 2026 HeadySystems Inc. — Eric Haywood (eric@headysystems.com) — 51 Provisional Patents
# Target: < 100MB distroless image
# All timing constants derive from φ (1.618) or Fibonacci — ZERO magic numbers.

ARG SERVICE_NAME=heady-service

# ─── Stage 1: Builder ──────────────────────────────────────────────────────
# Full Node.js environment for installing dependencies and preparing artifacts
FROM node:20-slim AS builder

WORKDIR /build

# Copy root package files for workspace resolution
COPY package*.json ./

# Copy shared phi-math foundation (single source of truth for all constants)
COPY shared/ ./shared/

# Copy service-specific package files for dependency caching
ARG SERVICE_NAME
COPY services/${SERVICE_NAME}/package*.json ./services/${SERVICE_NAME}/

# Install production dependencies only — workspace-aware with fallback
RUN npm ci --production --workspace=services/${SERVICE_NAME} 2>/dev/null \
    || npm ci --production

# Copy service source, core modules, and config
COPY services/${SERVICE_NAME}/ ./services/${SERVICE_NAME}/
COPY src/ ./src/
COPY configs/ ./configs/

# Prune dev artifacts and caches to minimize image size
RUN rm -rf /build/node_modules/.cache \
    && find /build -name "*.md" -not -name "CLAUDE.md" -delete 2>/dev/null; true

# ─── Stage 2: Production (Distroless) ─────────────────────────────────────
# Minimal runtime — no shell, no package manager, < 100MB final image
FROM gcr.io/distroless/nodejs20-debian12

# Labels for traceability
LABEL maintainer="Eric Haywood <eric@headysystems.com>"
LABEL org.opencontainers.image.title="Heady™ ${SERVICE_NAME}"
LABEL org.opencontainers.image.vendor="HeadySystems Inc."
LABEL org.opencontainers.image.description="Heady™ sovereign AI platform service — φ-scaled architecture"

WORKDIR /app

# Copy built artifacts from builder stage
COPY --from=builder /build/ .

# Production environment
ENV NODE_ENV=production
ENV HEADY_VERSION=5.1.0

# Service identification
ARG SERVICE_NAME
ENV SERVICE_NAME=${SERVICE_NAME}

# Default port — overridden per service via SERVICE_PORT env var
EXPOSE 8080

# Health check using φ-derived timing:
#   interval:     4236ms = φ³ × 1000 (4s rounded for Docker)
#   timeout:      2618ms = φ² × 1000 (3s rounded for Docker)
#   retries:      3      = fib(4)
#   start_period: 6854ms = φ⁴ × 1000 (7s rounded for Docker)
HEALTHCHECK --interval=4s --timeout=3s --retries=3 --start-period=7s \
  CMD ["node", "-e", \
    "const p=process.env.SERVICE_PORT||8080;require('http').get('http://localhost:'+p+'/health',r=>{r.statusCode===200?process.exit(0):process.exit(1)}).on('error',()=>process.exit(1))"]

# Run as non-root (distroless default user 65534/nobody)
USER 65534

# Launch the service
CMD ["node", "services/${SERVICE_NAME}/index.js"]
