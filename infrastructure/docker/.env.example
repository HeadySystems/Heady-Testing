# Copy to .env and fill in values

# ─── Core ──────────────────────────────────────────────────────
NODE_ENV=production
HEADY_ENV=production
HEADY_VERSION=5.1.0

# ─── GCP ───────────────────────────────────────────────────────
GCP_PROJECT=gen-lang-client-0920560496
GCP_REGION=us-east1
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-key.json

# ─── Firebase ──────────────────────────────────────────────────
FIREBASE_PROJECT_ID=gen-lang-client-0920560496
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=gen-lang-client-0920560496.firebaseapp.com

# ─── Cloudflare ────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=8b1fa38f282c691423c6399247d53323
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ─── Database ──────────────────────────────────────────────────
PGVECTOR_PASSWORD=
PGVECTOR_URL=postgresql://heady:${PGVECTOR_PASSWORD}@pgvector:5432/heady
PGVECTOR_POOL_SIZE=34
PGVECTOR_MAX_CONNECTIONS=233

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_MAX_MEMORY=233mb

# ─── NATS ──────────────────────────────────────────────────────
NATS_URL=nats://nats:4222
NATS_MAX_PAYLOAD=1048576

# ─── Auth ──────────────────────────────────────────────────────
SESSION_SECRET=
SESSION_TTL_MS=29034000
COOKIE_DOMAIN=.headysystems.com

# ─── External APIs ─────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=
HUGGINGFACE_API_KEY=

# ─── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Monitoring ────────────────────────────────────────────────
GRAFANA_PASSWORD=
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ─── Colab Pro+ ────────────────────────────────────────────────
COLAB_RUNTIME_HOT_URL=
COLAB_RUNTIME_WARM_URL=
COLAB_RUNTIME_COLD_URL=
COLAB_AUTH_TOKEN=
