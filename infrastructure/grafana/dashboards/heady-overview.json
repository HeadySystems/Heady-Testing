{
  "dashboard": {
    "title": "Heady\u2122 System Overview",
    "tags": [
      "heady",
      "sacred-geometry"
    ],
    "timezone": "browser",
    "panels": [
      {
        "title": "Service Health",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 8,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "count(up{job=\"heady-services\"} == 1)",
            "legendFormat": "Healthy"
          }
        ]
      },
      {
        "title": "Request Rate (\u03c6-scaled buckets)",
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 4
        },
        "targets": [
          {
            "expr": "sum(rate(heady_http_requests_total[5m])) by (service)",
            "legendFormat": "{{service}}"
          }
        ]
      },
      {
        "title": "Colab GPU Utilization",
        "type": "gauge",
        "gridPos": {
          "h": 4,
          "w": 8,
          "x": 8,
          "y": 0
        },
        "targets": [
          {
            "expr": "heady_colab_gpu_util",
            "legendFormat": "{{pool}}"
          }
        ]
      },
      {
        "title": "CSL Gate Scores",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 4
        },
        "targets": [
          {
            "expr": "heady_csl_gate_score",
            "legendFormat": "{{gate}}"
          }
        ]
      },
      {
        "title": "Vector Memory Operations",
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 12
        },
        "targets": [
          {
            "expr": "rate(heady_vector_ops_total[5m])",
            "legendFormat": "{{operation}}"
          }
        ]
      },
      {
        "title": "\u03c6-Backoff Retries",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 8,
          "x": 12,
          "y": 12
        },
        "targets": [
          {
            "expr": "sum(heady_retries_total) by (service)",
            "legendFormat": "{{service}}"
          }
        ]
      }
    ]
  }
}