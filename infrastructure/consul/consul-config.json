        "version": "5.1.0",
        "phi_health_interval_ms": "4236",
        "domain": "inference"
      },
      "check": {
        "http": "http://heady-brain:3310/health",
        "interval": "13s",
        "timeout": "5s",
        "deregister_critical_service_after": "89s"
      },
      "connect": {
        "sidecar_service": {
          "proxy": {
            "upstreams": [
              { "destination_name": "heady-memory", "local_bind_port": 13316 },
