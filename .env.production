# ═══════════════════════════════════════════════════════════
# Heady™ Liquid Latent OS v4.0.0 — Production Environment
# ═══════════════════════════════════════════════════════════

# ── Runtime ──────────────────────────────────────────────
NODE_ENV=production
HEADY_ENV=production
HEADY_VERSION=4.0.0
PORT=3301
LOG_LEVEL=info
EMBEDDINGS_PROVIDER=openai
MEMORY_STORE_PATH=./data/memory
MCP_BEARER_TOKEN=${MCP_BEARER_TOKEN}

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:5432/${DB_NAME}?sslmode=require
PGBOUNCER_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${PGBOUNCER_HOST}:6432/${DB_NAME}
REDIS_URL=redis://${REDIS_HOST}:6379

# ── AI Providers ─────────────────────────────────────────
OPENAI_API_KEY=${OPENAI_API_KEY}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
GOOGLE_API_KEY=${GOOGLE_API_KEY}
GROQ_API_KEY=${GROQ_API_KEY}
PERPLEXITY_API_KEY=${PERPLEXITY_API_KEY}
HF_TOKEN=${HF_TOKEN}

# ── Authentication ───────────────────────────────────────
JWT_SECRET=${JWT_SECRET}
SESSION_SECRET=${SESSION_SECRET}
ED25519_KEY_PAIR=${ED25519_KEY_PAIR}
HEADY_API_KEY=${HEADY_API_KEY}

# ── Google Cloud ─────────────────────────────────────────
GCP_PROJECT_ID=gen-lang-client-0920560496
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_EMAIL=${GCP_SA_EMAIL}
CLOUD_RUN_SERVICE=heady-manager
CLOUD_RUN_ORIGIN=https://manager.headysystems.com

# ── Cloudflare ───────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=${CF_ACCOUNT_ID}
CLOUDFLARE_API_TOKEN=${CF_API_TOKEN}
CF_ZONE_HEADYME=${CF_ZONE_HEADYME}
CF_ZONE_HEADYSYSTEMS=${CF_ZONE_HEADYSYSTEMS}
CF_ZONE_HEADYBUDDY=${CF_ZONE_HEADYBUDDY}
CF_ZONE_HEADYMCP=${CF_ZONE_HEADYMCP}
CF_ZONE_HEADYIO=${CF_ZONE_HEADYIO}
CF_ZONE_HEADYCONNECTION=${CF_ZONE_HEADYCONNECTION}
CF_ZONE_HEADYAPI=${CF_ZONE_HEADYAPI}
CF_ZONE_HEADYOS=${CF_ZONE_HEADYOS}
CF_ZONE_HEADYWEB=${CF_ZONE_HEADYWEB}

# ── Service URLs ─────────────────────────────────────────
HEADY_MANAGER_URL=https://manager.headysystems.com
HEADY_BRAIN_URL=https://headyio.com/mcp
HEADY_EMBED_URL=http://heady-embed:4312
HEADY_INFER_URL=http://heady-infer:4310
HEADY_VECTOR_URL=http://heady-vector:4313
HEADY_CHAIN_URL=http://heady-chain:4314
HEADY_CACHE_URL=http://heady-cache:4309
HEADY_GUARD_URL=http://heady-guard:4316
HEADY_EVAL_URL=http://heady-eval:4315
HEADY_MCP_URL=http://heady-mcp:4317

# ── Observability ────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=heady-manager
HEADY_FLAG_OTEL_TRACES=true
HEADY_FLAG_AUDIT_LOGGING=true

# ── Feature Flags ────────────────────────────────────────
ENABLE_VECTOR_MEMORY=true
ENABLE_SWARM=true
ENABLE_MCP=true
ENABLE_VOICE=true
ENABLE_PQC=true
HEADY_FLAG_PROMPT_GUARD=true
HEADY_FLAG_CANARY_DEPLOY=true
HEADY_FLAG_EVAL_PIPELINE=true

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=100
MCP_RATE_LIMIT=100

# ── Sacred Geometry (phi-derived constants) ────────────────
PHI=1.6180339887
PSI=0.6180339887
AUTO_SUCCESS_CYCLE_MS=29034
TASK_TIMEOUT_MS=4236
CSL_GATE_THRESHOLD=0.618
BEE_POOL_HOT_PCT=34
BEE_POOL_WARM_PCT=21
BEE_POOL_COLD_PCT=13
BEE_POOL_RESERVE_PCT=8
BEE_POOL_GOVERNANCE_PCT=5
MAX_BEE_TYPES=89
MAX_CONCURRENT_BEES=10000
PIPELINE_STAGES=21
AUTO_SUCCESS_CATEGORIES=13
AUTO_SUCCESS_TASKS=144

# ── Failover ─────────────────────────────────────────────
PRIMARY_BACKEND_URL=https://manager.headysystems.com
FALLBACK_BACKEND_URL=https://api.headysystems.com
KEY_TTL_MS=86400000
SHUTDOWN_TIMEOUT_MS=5000
WORKER_POOL_SIZE=4
