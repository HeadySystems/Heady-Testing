{
  "name": "heady-systems",
  "version": "3.0.0",
  "description": "Heady Systems - Sacred Geometry :: Organic Systems :: Breathing Interfaces",
  "main": "heady-manager.js",
  "scripts": {
    "start:mcp": "node backend/app.js",
    "cli": "python scripts/heady_cli.py",
    "start": "node heady-manager.js",
    "dev": "nodemon heady-manager.js",
    "build": "npm run build --prefix frontend",
    "frontend": "npm run dev --prefix frontend",
    "backend": "npm start --prefix backend",
    "test": "pwsh ./scripts/kill-port.ps1 && jest",
    "lint": "eslint . --fix",
    "lint:fix": "eslint . --fix",
    "pipeline": "node -e \"const {pipeline}=require('./src/hc_pipeline');pipeline.run().then(s=>console.log(JSON.stringify({runId:s.runId,status:s.status},null,2))).catch(e=>console.error(e.message))\"",
    "pipeline:config": "node -e \"const {pipeline}=require('./src/hc_pipeline');console.log(JSON.stringify(pipeline.getConfigSummary(),null,2))\"",
    "sync": "powershell -File ./scripts/Heady-Sync.ps1",
    "brand:check": "node scripts/brand_headers.js --check",
    "brand:fix": "node scripts/brand_headers.js --fix",
    "test:domains": "node scripts/domain-connectivity-test.js",
    "test:branding": "node scripts/validate-branding.js",
    "build-all": "npm run build && npm run build:desktop && npm run build:mobile",
    "build:desktop": "cd headybrowser-desktop && npm run build",
    "build:mobile": "cd headybrowser-mobile && npm run build",
    "deploy": "node scripts/deploy.js",
    "deploy:auto": "node scripts/deploy.js --auto",
    "services:start": "node src/services/service-manager.js",
    "services:status": "node -e \"const {getServiceManager}=require('./src/services/service-manager');const mgr=getServiceManager();mgr.start().then(()=>console.log(JSON.stringify(mgr.getStatus(),null,2)))\"",
    "hcfp": "node scripts/hcfp-full-auto.js",
    "hcfp:full-auto": "node scripts/hcfp-full-auto.js --full-auto",
    "hcfp:HeadySims": "node scripts/hcfp-full-auto.js --HeadySims",
    "hcfp:HeadyBattle": "node scripts/hcfp-full-auto.js --HeadyBattle",
    "hcfp:arena": "node scripts/hcfp-full-auto.js --arena",
    "branch:sync": "node scripts/branch-sync.js",
    "branch:dev-to-staging": "node scripts/branch-sync.js --dev-to-staging",
    "branch:staging-to-main": "node scripts/branch-sync.js --staging-to-main",
    "branch:continuous": "node scripts/branch-sync.js --continuous"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@google/genai": "^1.42.0",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/inference": "^4.13.12",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "@octokit/auth-app": "^8.2.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "commander": "^14.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "electron": "40.2.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "groq-sdk": "^0.37.0",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "minimatch": "^10.2.2",
    "node-cron": "^3.0.2",
    "node-fetch": "^2.7.0",
    "pg": "^8.18.0",
    "replace-in-file": "^8.4.0",
    "swagger-ui-express": "^5.0.1",
    "tinyliquid": "^0.2.34",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "yamljs": "^0.1.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.55.0",
    "concurrently": "^9.1.2",
    "eslint": "^10.0.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "yaml-jest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "offline": {
    "nodeModulesPath": "./offline-packages/node_modules",
    "pythonPackagesPath": "./offline-packages/python-libs"
  },
  "overrides": {
    "glob": {
      "minimatch": ">=10.2.1"
    },
    "test-exclude": {
      "minimatch": ">=10.2.1"
    },
    "rimraf": {
      "glob": ">=11.0.0"
    }
  }
}
