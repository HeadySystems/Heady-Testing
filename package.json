{
  "name": "heady",
  "version": "0.2.0",
  "description": "Heady Latent OS — Autonomous AI Platform",
  "main": "heady-manager.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node heady-manager.js",
    "dev": "NODE_ENV=development node --watch heady-manager.js",
    "build": "cd src/web && npm run build",
    "test": "mocha tests/unit/**/*.test.js --timeout 10000",
    "test:int": "mocha tests/integration/**/*.test.js --timeout 30000",
    "test:e2e": "mocha tests/e2e/**/*.test.js --timeout 60000",
    "test:smoke": "bash scripts/smoke-test.sh",
    "lint": "eslint src/ --ext .js,.jsx",
    "format": "prettier --write 'src/**/*.{js,jsx,json}'",
    "validate:env": "node scripts/validate-env.js",
    "setup": "bash scripts/setup.sh",
    "docker:build": "docker build -t heady:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "prom-client": "^15.1.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "mocha": "^10.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HeadyMe/Heady-8f71ffc8.git"
  },
  "author": "HeadySystems Inc. & HeadyConnection Inc.",
  "license": "SEE LICENSE IN LICENSE",
  "private": true
}
