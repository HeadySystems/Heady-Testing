{
  "name": "heady-liquid-latent-os",
  "version": "4.0.0",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "predeploy": "node ./scripts/predeploy-check.mjs",
    "smoke": "node ./scripts/smoke-test.mjs",
    "validate:no-localhost": "node ./scripts/validate-no-localhost.mjs",
    "generate:service-map": "node ./scripts/generate-service-manifests.mjs",
    "test:shared-config": "node --test tests/shared-config.node.test.mjs",
    "rebuild:bundle": "python3 scripts/rebuild_sacred_genesis.py",
    "rebuild:zip": "python3 scripts/make_zip.py",
    "rebuild:audit": "node scripts/audit-naming-conventions.js",
    "rebuild:audit:strict": "node --experimental-vm-modules scripts/naming-convention-audit.mjs --strict",
    "rebuild:all": "npm run rebuild:audit && npm run rebuild:bundle"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "tsx": "^4.19.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8",
    "yaml": "^2.7.0"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  }
}