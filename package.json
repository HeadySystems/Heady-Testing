{
  "name": "heady-systems",
  "version": "3.2.0",
  "description": "Heady Systems - Sacred Geometry :: Organic Systems :: Breathing Interfaces",
  "main": "heady-manager.js",
  "packageManager": "pnpm@10.6.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "node scripts/link-packages.js",
    "start": "node heady-manager.js",
    "start:mcp": "node backend/app.js",
    "start:production": "pm2 start ecosystem.config.cjs --env production",
    "stop:production": "pm2 stop ecosystem.config.cjs",
    "logs:production": "pm2 logs --lines 100",
    "dev": "turbo run dev --parallel",
    "cli": "python scripts/heady_cli.py",
    "build": "turbo run build",
    "build:production": "NODE_ENV=production turbo run build:production",
    "build-all": "npm run build && npm run build:desktop && npm run build:mobile",
    "build:desktop": "npm run build --prefix apps/desktop",
    "build:mobile": "sh ./headybuddy-mobile/gradlew -p ./headybuddy-mobile assembleDebug",
    "frontend": "npm run dev --prefix apps/headyweb",
    "backend": "npm start --prefix backend",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "pipeline": "node -e \"const {pipeline}=require('./src/hc_pipeline');pipeline.run().then(s=>console.log(JSON.stringify({runId:s.runId,status:s.status},null,2))).catch(e=>console.error(e.message))\"",
    "pipeline:config": "node -e \"const {pipeline}=require('./src/hc_pipeline');console.log(JSON.stringify(pipeline.getConfigSummary(),null,2))\"",
    "sync": "powershell -File ./scripts/Heady-Sync.ps1",
    "brand:check": "node scripts/brand_headers.js --check",
    "brand:fix": "node scripts/brand_headers.js --fix",
    "test:domains": "node scripts/domain-connectivity-test.js",
    "test:branding": "node scripts/validate-branding.js",
    "test:shared-config": "node --test tests/shared-config.node.test.mjs",
    "predeploy": "node ./scripts/predeploy-check.mjs",
    "smoke": "node ./scripts/smoke-test.mjs",
    "validate:no-localhost": "node ./scripts/validate-no-localhost.mjs",
    "generate:service-map": "node ./scripts/generate-service-manifests.mjs",
    "deploy": "node scripts/deploy.js",
    "deploy:auto": "node scripts/deploy.js --auto",
    "deploy:sites": "bash ./scripts/deploy-all.sh",
    "deploy:cloud-run": "node scripts/deploy.js --target cloudrun",
    "deploy:workers": "turbo run deploy --filter='./workers/*'",
    "deploy:all": "npm run build:production && npm run deploy:workers && npm run deploy:sites",
    "health:check": "bash ./scripts/health-check-all.sh",
    "rebuild:bundle": "python3 scripts/rebuild_sacred_genesis.py",
    "rebuild:zip": "python3 scripts/make_zip.py",
    "rebuild:audit": "node scripts/audit-naming-conventions.js",
    "rebuild:audit:strict": "node --experimental-vm-modules scripts/naming-convention-audit.mjs --strict",
    "rebuild:all": "npm run rebuild:audit && npm run rebuild:bundle",
    "rebuild:liquid-latent": "node scripts/autonomous/rebuild-liquid-latent-os.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "psql $DATABASE_URL -f scripts/init-db.sql",
    "auto:setup": "node scripts/heady-git-setup.js",
    "auto:push": "node -e \"const {AutoGit}=require('./services/heady-auto');const g=new AutoGit();g.setupCredentials();const r=g.commitAndPush();console.log(JSON.stringify(r,null,2))\"",
    "auto:deploy": "node -e \"const {AutoDeploy}=require('./services/heady-auto');const d=new AutoDeploy();d.runPipeline({deploy:true}).then(r=>console.log(JSON.stringify(r,null,2)))\"",
    "auto:import": "node -e \"const {AutoImport}=require('./services/heady-auto');const i=new AutoImport();console.log(JSON.stringify(i.scanAndImport(),null,2))\"",
    "auto:health": "node -e \"const {AutoHealth}=require('./services/heady-auto');const h=new AutoHealth();h.checkAll().then(r=>console.log(JSON.stringify(r,null,2)))\"",
    "auto:full": "node -e \"const {HeadyAuto}=require('./services/heady-auto');const a=new HeadyAuto();a.init();const {AutoDeploy}=require('./services/heady-auto');const d=new AutoDeploy();d.runPipeline().then(r=>console.log(JSON.stringify(r,null,2)))\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@google-cloud/secret-manager": "^6.1.1",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "commander": "^14.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "dotenv-expand": "^12.0.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "fastify": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "groq-sdk": "^1.1.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.2",
    "openai": "^6.29.0",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "replace-in-file": "^8.4.0",
    "stripe": "^20.4.1",
    "swagger-ui-express": "^5.0.1",
    "tinyliquid": "^0.2.34",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "yamljs": "^0.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "concurrently": "^9.1.2",
    "electron": "^40.8.0",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "jest-transform-yaml": "^1.2.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "turbo": "^2.4.4",
    "typescript": "^5.9.3",
    "vitest": "^3.0.8",
    "yaml-jest": "^1.2.0"
  }
}
