{
  "name": "heady-latent-os",
  "version": "3.2.0",
  "description": "Self-aware, self-correcting intelligence infrastructure — the Heady Latent OS",
  "main": "heady-manager.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node heady-manager.js",
    "start:mcp": "node backend/app.js",
    "dev": "node --watch heady-manager.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .js,.mjs",
    "lint:fix": "eslint src/ --ext .js,.mjs --fix",
    "build:frontend": "cd frontend && vite build",
    "build": "npm run build --prefix frontend",
    "frontend": "npm run dev --prefix frontend",
    "backend": "npm start --prefix backend",
    "docker:build": "podman build -t heady:latest .",
    "docker:run": "podman run -d -p 3301:3301 -v heady-data:/app/data heady:latest",
    "health": "curl -s https://heady.headysystems.com/health | jq",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "deploy": "node scripts/deploy.js",
    "deploy:auto": "node scripts/deploy.js --auto",
    "pipeline": "node -e \"const {pipeline}=require('./src/hc_pipeline');pipeline.run().then(s=>console.log(JSON.stringify({runId:s.runId,status:s.status},null,2))).catch(e=>console.error(e.message))\"",
    "pipeline:config": "node -e \"const {pipeline}=require('./src/hc_pipeline');console.log(JSON.stringify(pipeline.getConfigSummary(),null,2))\"",
    "brand:check": "node scripts/brand_headers.js --check",
    "brand:fix": "node scripts/brand_headers.js --fix",
    "test:domains": "node scripts/domain-connectivity-test.js",
    "test:branding": "node scripts/validate-branding.js",
    "audit:fix": "npm audit fix --force",
    "cli": "python scripts/heady_cli.py"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@google/generative-ai": "^0.21.0",
    "@heady/phi-math": "file:packages/phi-math",
    "@heady/structured-logger": "file:packages/structured-logger",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "@notionhq/client": "^2.2.15",
    "@octokit/auth-app": "^8.2.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "commander": "^14.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "eventsource": "^3.0.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "concurrently": "^9.1.2",
    "electron": "^40.8.0",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "jest-transform-yaml": "^1.2.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.3.3",
    "supertest": "^7.2.2",
    "vitest": "^2.1.3",
    "yaml-jest": "^1.2.0"
  },
  "offline": {
    "nodeModulesPath": "./offline-packages/node_modules",
    "pythonPackagesPath": "./offline-packages/python-libs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HeadyMe/Heady-8f71ffc8.git"
  },
  "author": "HeadySystems Inc.",
  "license": "UNLICENSED"
}
