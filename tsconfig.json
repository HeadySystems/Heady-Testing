{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": [
            "ES2022"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "allowJs": true,
        "checkJs": false,
        "noEmit": false,
        "moduleResolution": "node",
        "types": [
            "node",
            "jest"
        ],
        "baseUrl": ".",
        "paths": {
            "@heady-ai/config/*": ["src/config/*"],
            "@heady-ai/orchestration/*": ["src/orchestration/*"],
            "@heady-ai/memory/*": ["src/memory/*"],
            "@heady-ai/auth/*": ["src/auth/*"],
            "@heady-ai/mcp/*": ["src/mcp/*"],
            "@heady-ai/agents/*": ["src/agents/*"],
            "@heady-ai/observability/*": ["src/observability/*"],
            "@heady-ai/shared/*": ["src/shared/*"],
            "@heady-ai/services/*": ["src/services/*"],
            "@heady-ai/bees/*": ["src/bees/*"],
            "@heady-ai/gateway/*": ["src/gateway/*"],
            "@heady-ai/core/*": ["src/core/*"],
            "@heady-ai/engines/*": ["src/engines/*"],
            "@heady-ai/hcfp/*": ["src/hcfp/*"],
            "@heady-ai/resilience/*": ["src/resilience/*"],
            "@heady-ai/security/*": ["src/security/*"],
            "@heady-ai/routing/*": ["src/routing/*"],
            "@heady-ai/middleware/*": ["src/middleware/*"],
            "@heady-ai/intelligence/*": ["src/intelligence/*"],
            "@heady-ai/persona/*": ["src/persona/*"],
            "@heady-ai/trading/*": ["src/trading/*"],
            "@heady-ai/creative/*": ["src/creative/*"],
            "@heady-ai/vsa/*": ["src/vsa/*"],
            "@heady-ai/edge/*": ["src/edge/*"],
            "@heady-ai/telemetry/*": ["src/telemetry/*"]
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.js"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "_archive",
        "tests"
    ]
}