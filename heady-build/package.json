{
  "name": "@heady-ai/liquid-latent-os",
  "version": "1.0.0",
  "description": "Heady Liquid Latent OS — φ-resonant cognitive infrastructure",
  "author": "Heady AI <eric@headyconnection.org>",
  "license": "UNLICENSED",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "start": "node --max-old-space-size=512 dist/main.js",
    "dev": "ts-node --project tsconfig.json src/main.ts",
    "lint": "eslint 'src/**/*.ts' 'packages/**/*.ts' --ext .ts",
    "lint:fix": "eslint 'src/**/*.ts' 'packages/**/*.ts' --ext .ts --fix",
    "test": "jest --passWithNoTests --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prebuild": "npm run clean"
  },
  "dependencies": {
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-transport": "^4.9.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.2",
    "ioredis": "^5.4.2",
    "pg": "^8.14.0",
    "openai": "^4.91.1",
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "ws": "^8.18.1",
    "node-fetch": "^3.3.2",
    "p-limit": "^6.2.0",
    "p-retry": "^6.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.13.9",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "rimraf": "^6.0.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/packages"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/*.spec.ts",
      "**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@heady-ai/(.*)$": "<rootDir>/packages/$1/src/index.ts"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "packages/**/src/**/*.ts",
      "!**/*.d.ts"
    ]
  },
  "keywords": [
    "heady",
    "liquid-latent",
    "cognitive-architecture",
    "phi-resonant",
    "ai-orchestration"
  ]
}
