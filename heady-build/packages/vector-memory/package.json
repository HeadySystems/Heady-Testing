{
  "name": "@heady-ai/vector-memory",
  "version": "1.0.0",
  "description": "3-D vector memory system with PCA projection, cosine-similarity search, drift detection, and Alive Software heartbeat",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "keywords": [
    "vector-memory",
    "embeddings",
    "semantic-search",
    "3d-projection",
    "drift-detection",
    "heady-ai",
    "pgvector"
  ],
  "author": "Heady AI Team",
  "license": "MIT",
  "dependencies": {
    "@heady-ai/phi-math-foundation": "workspace:*",
    "@heady-ai/csl-engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
