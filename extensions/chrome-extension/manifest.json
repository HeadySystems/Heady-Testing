{
    "manifest_version": 3,
    "name": "HeadyBuddy — Your AI Companion",
    "short_name": "HeadyBuddy",
    "version": "3.2.3",
    "description": "HeadyBuddy — your branded AI companion sidebar. See Buddy's output beautifully rendered with Sacred Geometry visuals and pretty-printed text.",
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png"
        },
        "default_title": "Open HeadyBuddy"
    },
    "side_panel": {
        "default_path": "sidebar.html"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "permissions": [
        "storage",
        "sidePanel",
        "activeTab"
    ],
    "host_permissions": [
        "https://headyapi.com/*",
        "https://headymcp.com/*",
        "https://heady-ai.com/*",
        "https://headybuddy.org/*",
        "https://headyio.com/*",
        "https://headyos.com/*",
        "https://headycloud.com/*",
        "https://headysecure.com/*",
        "https://headydb.com/*",
        "https://headyme.com/*",
        "https://headysystems.com/*",
        "https://headyconnection.org/*"
    ]
}