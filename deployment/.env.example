# ============================================================
# Heady Liquid Latent OS — Environment Configuration
# Copy to .env and populate all values before running.
# NEVER commit a populated .env file to version control.
# ============================================================

# ---------------------
# Runtime environment
# ---------------------
NODE_ENV=production
PORT=3300
LOG_LEVEL=info

# ---------------------
# Database
# ---------------------
DATABASE_URL=postgresql://heady_user:CHANGE_ME@db.example.com:5432/heady_prod?sslmode=require

# ---------------------
# Redis / Cache
# ---------------------
REDIS_URL=rediss://heady_user:CHANGE_ME@redis.example.com:6380/0

# ---------------------
# OpenAI
# ---------------------
OPENAI_API_KEY=sk-proj-CHANGE_ME
OPENAI_ORG_ID=org-CHANGE_ME

# ---------------------
# Anthropic
# ---------------------
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ---------------------
# Google AI (Gemini)
# ---------------------
GOOGLE_AI_API_KEY=AIzaCHANGE_ME
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# ---------------------
# Cloudflare
# ---------------------
CLOUDFLARE_API_TOKEN=CHANGE_ME
CLOUDFLARE_ACCOUNT_ID=CHANGE_ME
CLOUDFLARE_ZONE_ID=CHANGE_ME
CLOUDFLARE_WORKER_NAME=heady-edge

# ---------------------
# VPC / Networking (Cloud Run)
# ---------------------
VPC_CONNECTOR=projects/your-gcp-project-id/locations/us-central1/connectors/heady-vpc-connector

# ---------------------
# Vector Memory
# ---------------------
# φ-resonant 384-dimensional embedding space
VECTOR_DIMENSIONS=384
# 3D projection for visualization (φ³ = 3)
PROJECTION_DIMENSIONS=3

# ---------------------
# Cognitive Engine Flags
# ---------------------
AUTO_SUCCESS_ENABLED=true
PIPELINE_FULL_AUTO=false
CSL_GATES_ENABLED=true
SOCRATIC_LOOP_ENABLED=true

# ---------------------
# φ-Resonance Tuning
# ---------------------
# φ = 1.6180339887498948482
PHI_PRECISION=15
# Fibonacci heartbeat multiplier (φ⁷ ≈ 29.034)
HEARTBEAT_MULTIPLIER=7
# Base rate limiting: 120 req/min (φ-scaled)
RATE_LIMIT_BASE_RPM=120

# ---------------------
# Heady Soul Archetypes
# Comma-separated list of 7 cognitive archetypes
# ---------------------
SOUL_ARCHETYPES=explorer,architect,synthesizer,guardian,catalyst,witness,integrator

# ---------------------
# Service Identity
# ---------------------
SERVICE_NAME=heady-liquid-latent-os
SERVICE_VERSION=1.0.0
DEPLOYMENT_REGION=us-central1

# ---------------------
# Observability / Tracing
# ---------------------
OTEL_SERVICE_NAME=heady-liquid-latent-os
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# ---------------------
# Graceful Shutdown
# ---------------------
# Drain timeout in milliseconds before force-kill
SHUTDOWN_DRAIN_MS=10000
