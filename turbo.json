{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env.production"],
  "globalEnv": ["NODE_ENV", "HEADY_ENV", "HEADY_VERSION"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV"]
    },
    "build:production": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV", "HEADY_VERSION"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"],
      "env": ["NODE_ENV"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "clean": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["build:production", "test", "lint"],
      "cache": false
    }
  }
}
