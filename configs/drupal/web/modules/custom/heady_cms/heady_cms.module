<?php

/**
 * @file
 * Heady™ Headless CMS — module hooks.
 *
 * Provides headless content delivery, task browser, and liquid node
 * orchestration for the Heady™ Liquid Latent OS ecosystem.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function heady_cms_help($route_name, RouteMatchInterface $route_match) {
  if ($route_name === 'help.page.heady_cms') {
    return '<p>Heady™ Headless CMS provides JSON:API content delivery for all 47 sites, '
      . 'headless browser task completion, and liquid node orchestration.</p>';
  }
}

/**
 * Implements hook_theme().
 */
function heady_cms_theme() {
  return [
    'heady_cms_content_manager' => [
      'variables' => [
        'sites' => [],
        'stats' => [],
        'recent_deploys' => [],
      ],
      'template' => 'heady-cms-content-manager',
    ],
    'heady_cms_task_browser' => [
      'variables' => [
        'tasks' => [],
        'queues' => [],
        'browser_status' => [],
      ],
      'template' => 'heady-cms-task-browser',
    ],
    'heady_cms_liquid_dashboard' => [
      'variables' => [
        'nodes' => [],
        'topology' => [],
        'vectors' => [],
        'phi_timing' => [],
      ],
      'template' => 'heady-cms-liquid-dashboard',
    ],
  ];
}

/**
 * Implements hook_cron().
 *
 * Runs φ-scaled maintenance: site health checks, stale task cleanup,
 * liquid node heartbeats.
 */
function heady_cms_cron() {
  $state = \Drupal::state();
  $last_run = $state->get('heady_cms.last_maintenance', 0);
  $phi_cycle = 29034; // PHI_TIMING.CYCLE in seconds / 1000

  // Only run every ~29s worth of cron cycles
  if ((\Drupal::time()->getRequestTime() - $last_run) < $phi_cycle) {
    return;
  }

  $state->set('heady_cms.last_maintenance', \Drupal::time()->getRequestTime());

  // Heartbeat liquid nodes
  $nodes = \Drupal::service('heady_cms.liquid_node_manager')->heartbeatAll();
  \Drupal::logger('heady_cms')->info('Liquid node heartbeat: @count nodes checked', ['@count' => count($nodes)]);
}

/**
 * Implements hook_page_attachments().
 */
function heady_cms_page_attachments(array &$attachments) {
  $route = \Drupal::routeMatch()->getRouteName();
  if (strpos($route, 'heady_cms.') === 0) {
    $attachments['#attached']['library'][] = 'heady_cms/liquid_dashboard';
  }
}
