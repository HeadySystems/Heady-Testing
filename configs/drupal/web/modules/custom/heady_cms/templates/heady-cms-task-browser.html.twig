{#
 # Heady™ Task Browser — headless browser task queue + automation
 #}
<div class="heady-task-browser">

  <div class="task-header">
    <h2>Task Browser</h2>
    <div class="task-stats">
      {% for queue_name, count in queues.queues %}
        <span class="stat">{{ queue_name }}: {{ count }}</span>
      {% endfor %}
    </div>
  </div>

  {# ── Browser Actions ── #}
  <div class="browser-actions">
    <h3>Quick Actions</h3>
    <div class="action-grid">
      <button class="action-btn" data-action="screenshot" title="Capture page screenshot">
        Screenshot
      </button>
      <button class="action-btn" data-action="deploy_verify" title="Verify all site deployments">
        Deploy Verify
      </button>
      <button class="action-btn" data-action="link_check" title="Check all links on a page">
        Link Check
      </button>
      <button class="action-btn" data-action="scrape" title="Extract structured data">
        Scrape
      </button>
      <button class="action-btn" data-action="lighthouse" title="Run Lighthouse audit">
        Lighthouse
      </button>
      <button class="action-btn" data-action="pdf_export" title="Export page as PDF">
        PDF Export
      </button>
    </div>
    <div class="action-url">
      <input type="url" id="browser-url" placeholder="https://headysystems.com">
      <button id="run-browser-task">Run</button>
    </div>
  </div>

  {# ── Task Queue ── #}
  <div class="task-queue">
    <h3>Task Queue <span class="queue-count">{{ queues.total }} total</span></h3>
    <div class="task-filters">
      <select id="task-status-filter">
        <option value="all">All</option>
        <option value="pending">Pending</option>
        <option value="running">Running</option>
        <option value="completed">Completed</option>
        <option value="failed">Failed</option>
      </select>
    </div>
    <div class="task-list" id="task-list">
      {% for task in tasks %}
        <div class="task-item task-{{ task.status }}" data-task="{{ task.id }}">
          <div class="task-title">{{ task.title }}</div>
          <div class="task-meta">
            <span class="task-type">{{ task.type }}</span>
            <span class="task-queue">{{ task.queue }}</span>
            <span class="task-status">{{ task.status }}</span>
          </div>
          <div class="task-actions">
            {% if task.status == 'pending' %}
              <button class="task-action" data-action="start">Start</button>
            {% endif %}
            {% if task.status == 'running' %}
              <button class="task-action" data-action="pause">Pause</button>
            {% endif %}
            {% if task.status == 'failed' %}
              <button class="task-action" data-action="retry">Retry</button>
            {% endif %}
            <button class="task-action" data-action="cancel">Cancel</button>
          </div>
        </div>
      {% else %}
        <div class="task-empty">No tasks in queue</div>
      {% endfor %}
    </div>
  </div>

  {# ── Browser Service Status ── #}
  <div class="browser-status">
    <h3>Browser Service</h3>
    <div id="browser-service-status">Checking...</div>
  </div>

</div>
