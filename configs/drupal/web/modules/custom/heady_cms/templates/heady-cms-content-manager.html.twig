{#
 # Heady™ Content Manager — headless CMS for all 47 sites
 #}
<div class="heady-content-manager">

  <div class="content-header">
    <h2>Content Manager</h2>
    <div class="content-stats">
      <span class="stat">{{ stats.total_content }} items</span>
      <span class="stat">{{ stats.total_sites }} sites</span>
      <span class="stat">{{ stats.api_mode }}</span>
    </div>
  </div>

  <div class="sites-grid">
    {% for site in sites %}
      <div class="site-card">
        <h4>{{ site.name }}</h4>
        <div class="site-meta">
          <span>{{ site.content_count }} items</span>
          {% if site.last_deploy %}
            <span>Deployed: {{ site.last_deploy }}</span>
          {% else %}
            <span class="no-deploy">Not deployed</span>
          {% endif %}
        </div>
        <div class="site-actions">
          <a href="/api/cms/content/{{ site.id }}" class="btn-api">API</a>
          <button class="btn-deploy" data-site="{{ site.id }}">Deploy</button>
        </div>
      </div>
    {% endfor %}
  </div>

</div>
