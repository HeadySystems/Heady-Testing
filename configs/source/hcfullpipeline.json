{
  "_meta": {
    "name": "HCFullPipeline",
    "version": "3.2.3",
    "description": "Heady™ AI Platform 21-Stage (fib(8)) Cognitive Pipeline — stage definitions, pool allocations, and execution config",
    "copyright": "© 2024-2026 HeadySystems Inc. All Rights Reserved.",
    "updatedAt": "2025-01-01T00:00:00Z"
  },
  "pipeline": {
    "id": "hcfullpipeline",
    "displayName": "HCFullPipeline",
    "mode": "sequential_with_parallel_stages",
    "maxDuration": 300000,
    "defaultTimeout": 30000,
    "retryPolicy": {
      "maxRetries": 3,
      "backoffMs": 1000,
      "backoffMultiplier": 2,
      "maxBackoffMs": 10000
    }
  },
  "fullAutoMode": {
    "enabled": false,
    "description": "When enabled, pipeline executes all stages autonomously without human checkpoints",
    "envOverride": "PIPELINE_FULL_AUTO",
    "requiresGovernancePass": true,
    "maxBudgetUSD": 5.00,
    "allowedScopes": [
      "read",
      "analyze",
      "generate"
    ],
    "prohibitedScopes": [
      "deploy",
      "delete",
      "external_write"
    ],
    "confirmationBypass": false
  },
  "stages": [
    {
      "id": "stage_intake",
      "name": "Task Intake & Classification",
      "order": 1,
      "required": true,
      "timeout": 5000,
      "parallel": false,
      "steps": [
        {
          "id": "parse_task",
          "name": "Parse and normalize task input",
          "node": "HeadyConductor",
          "action": "parse",
          "failFast": true
        },
        {
          "id": "classify_intent",
          "name": "Classify intent and domain",
          "node": "HeadySoul",
          "action": "analyze",
          "params": {
            "depth": "shallow"
          }
        },
        {
          "id": "governance_pre",
          "name": "Pre-execution governance check",
          "node": "HeadyGovernance",
          "action": "validate",
          "failFast": true,
          "params": {
            "phase": "pre"
          }
        }
      ]
    },
    {
      "id": "stage_memory",
      "name": "Memory & Context Retrieval",
      "order": 2,
      "required": true,
      "timeout": 10000,
      "parallel": true,
      "steps": [
        {
          "id": "vector_search",
          "name": "Semantic memory search",
          "node": "HeadyMemory",
          "action": "search",
          "params": {
            "limit": 10,
            "minScore": 0.7
          }
        },
        {
          "id": "pattern_lookup",
          "name": "Pattern recognition lookup",
          "node": "HeadyVinci",
          "action": "recognize",
          "params": {
            "mode": "fast"
          }
        },
        {
          "id": "story_context",
          "name": "Retrieve narrative context",
          "node": "HeadyAutobiographer",
          "action": "getStory",
          "params": {
            "limit": 20
          }
        }
      ]
    },
    {
      "id": "stage_routing",
      "name": "Conductor Routing & Planning",
      "order": 3,
      "required": true,
      "timeout": 10000,
      "parallel": false,
      "steps": [
        {
          "id": "route",
          "name": "Route to optimal execution path",
          "node": "HeadyConductor",
          "action": "route",
          "params": {
            "strategy": "best-of-n"
          }
        },
        {
          "id": "plan",
          "name": "Generate execution plan",
          "node": "HeadyBrains",
          "action": "plan",
          "params": {
            "maxSteps": 10
          }
        }
      ]
    },
    {
      "id": "stage_execution",
      "name": "Primary Execution",
      "order": 4,
      "required": true,
      "timeout": 120000,
      "parallel": false,
      "steps": [
        {
          "id": "execute",
          "name": "Execute primary task with Soul",
          "node": "HeadySoul",
          "action": "execute",
          "params": {
            "maxTokens": 16000
          }
        },
        {
          "id": "bee_spawn_if_needed",
          "name": "Spawn bee workers if parallel subtasks exist",
          "node": "HeadyBee",
          "action": "spawn",
          "conditional": "plan.parallelSubtasks.length > 0",
          "params": {
            "maxBees": 5
          }
        }
      ]
    },
    {
      "id": "stage_evaluation",
      "name": "Arena Evaluation & Quality Gate",
      "order": 5,
      "required": false,
      "timeout": 60000,
      "parallel": false,
      "enabledWhen": "task.requiresEvaluation === true || task.type === 'generation'",
      "steps": [
        {
          "id": "arena_battle",
          "name": "Run arena battle for quality selection",
          "node": "HeadyArena",
          "action": "battle",
          "params": {
            "rounds": 3,
            "criteria": [
              "accuracy",
              "quality",
              "efficiency",
              "safety"
            ]
          }
        },
        {
          "id": "monte_carlo",
          "name": "Monte Carlo confidence estimation",
          "node": "HeadyConductor",
          "action": "monteCarlo",
          "conditional": "task.requiresConfidence === true",
          "params": {
            "iterations": 500
          }
        }
      ]
    },
    {
      "id": "stage_learning",
      "name": "Learning & Memory Update",
      "order": 6,
      "required": true,
      "timeout": 15000,
      "parallel": true,
      "steps": [
        {
          "id": "embed_result",
          "name": "Embed and store result in vector memory",
          "node": "HeadyMemory",
          "action": "store",
          "params": {
            "namespace": "pipeline_results"
          }
        },
        {
          "id": "vinci_learn",
          "name": "Update Vinci pattern model",
          "node": "HeadyVinci",
          "action": "learn",
          "params": {
            "updateBaseline": true
          }
        },
        {
          "id": "corrections_check",
          "name": "Check for behavioral corrections",
          "node": "HeadyConductor",
          "action": "corrections",
          "params": {
            "subtle": true
          }
        }
      ]
    },
    {
      "id": "stage_governance_post",
      "name": "Post-Execution Governance",
      "order": 7,
      "required": true,
      "timeout": 5000,
      "parallel": false,
      "steps": [
        {
          "id": "governance_post",
          "name": "Post-execution governance audit",
          "node": "HeadyGovernance",
          "action": "audit",
          "params": {
            "phase": "post"
          }
        },
        {
          "id": "drift_check",
          "name": "Check semantic drift",
          "node": "HeadyConductor",
          "action": "driftCheck"
        }
      ]
    },
    {
      "id": "stage_story",
      "name": "Narrative Recording",
      "order": 8,
      "required": true,
      "timeout": 3000,
      "parallel": false,
      "steps": [
        {
          "id": "record_story",
          "name": "Log execution to autobiographer",
          "node": "HeadyAutobiographer",
          "action": "record",
          "params": {
            "events": [
              "pipeline_run",
              "decision_made",
              "learning_captured"
            ]
          }
        }
      ]
    },
    {
      "id": "stage_recon",
      "name": "Reconnaissance & Deep Scan",
      "order": 0.5,
      "required": true,
      "timeout": 6854,
      "parallel": true,
      "steps": [
        {
          "id": "scan_codebase",
          "name": "Scan codebase state and config drift",
          "node": "HeadyDeepScan",
          "action": "scan",
          "params": {
            "scope": "full",
            "driftThreshold": 0.618
          }
        },
        {
          "id": "scan_services",
          "name": "Scan all service health and attack surface",
          "node": "HeadyHealth",
          "action": "matrix",
          "params": {
            "includeAttackSurface": true
          }
        },
        {
          "id": "scan_dependencies",
          "name": "Scan dependency freshness and vulnerabilities",
          "node": "HeadyGuard",
          "action": "auditDeps",
          "params": {
            "freshnessWindowDays": 13
          }
        },
        {
          "id": "build_env_map",
          "name": "Build unified environment map",
          "node": "HeadyConductor",
          "action": "buildEnvMap"
        }
      ]
    },
    {
      "id": "stage_trial_and_error",
      "name": "Trial & Error Sandbox",
      "order": 3.5,
      "required": false,
      "timeout": 17944,
      "parallel": true,
      "enabledWhen": "task.allowTrials === true || task.complexity >= 'high'",
      "steps": [
        {
          "id": "generate_candidates",
          "name": "Generate candidate solutions",
          "node": "HeadyBrains",
          "action": "generateCandidates",
          "params": {
            "maxCandidates": 5
          }
        },
        {
          "id": "execute_trials",
          "name": "Execute trials in sandbox",
          "node": "HeadyBee",
          "action": "sandboxExecute",
          "params": {
            "isolation": "docker",
            "autoRollback": true
          }
        },
        {
          "id": "score_trials",
          "name": "Score trial outcomes via CSL",
          "node": "HeadyArena",
          "action": "scoreCandidates",
          "params": {
            "criteria": [
              "correctness",
              "performance",
              "safety",
              "elegance"
            ]
          }
        },
        {
          "id": "record_trial_learnings",
          "name": "Record trial learnings to vector memory",
          "node": "HeadyMemory",
          "action": "store",
          "params": {
            "namespace": "trial_learnings"
          }
        }
      ]
    },
    {
      "id": "stage_self_awareness",
      "name": "Self-Awareness Assessment",
      "order": 5.5,
      "required": true,
      "timeout": 11090,
      "parallel": false,
      "steps": [
        {
          "id": "calibrate_confidence",
          "name": "Assess confidence calibration accuracy",
          "node": "HeadySoul",
          "action": "introspect",
          "params": {
            "window": 21,
            "accuracyThreshold": 0.618
          }
        },
        {
          "id": "detect_blind_spots",
          "name": "Identify cognitive blind spots and biases",
          "node": "HeadyVinci",
          "action": "detectBiases",
          "params": {
            "methods": [
              "confirmation",
              "anchoring",
              "availability",
              "survivorship"
            ]
          }
        },
        {
          "id": "measure_predictions",
          "name": "Measure prediction accuracy vs actuals",
          "node": "HeadyConductor",
          "action": "measurePredictions",
          "params": {
            "lookbackRuns": 21
          }
        }
      ]
    },
    {
      "id": "stage_mistake_analysis",
      "name": "Mistake Analysis & Prevention",
      "order": 6.5,
      "required": true,
      "timeout": 11090,
      "parallel": false,
      "steps": [
        {
          "id": "catalog_failures",
          "name": "Catalog current and historical failures",
          "node": "HeadyMemory",
          "action": "search",
          "params": {
            "namespace": "failures",
            "limit": 89
          }
        },
        {
          "id": "root_cause",
          "name": "Perform root cause analysis (5-whys + fishbone)",
          "node": "HeadyBrains",
          "action": "rootCause",
          "params": {
            "method": "five_whys_plus_fishbone"
          }
        },
        {
          "id": "generate_guards",
          "name": "Generate prevention rules and anti-regression guards",
          "node": "HeadyGuard",
          "action": "generatePreventionRules",
          "params": {
            "format": "csl_gate"
          }
        },
        {
          "id": "immunize",
          "name": "Inject guards into pipeline and update wisdom.json",
          "node": "HeadyVinci",
          "action": "immunize",
          "params": {
            "updateWisdom": true,
            "updateRecon": true
          }
        }
      ]
    },
    {
      "id": "stage_optimization_ops",
      "name": "Optimization Ops Scanning",
      "order": 6.7,
      "required": true,
      "timeout": 17944,
      "parallel": true,
      "steps": [
        {
          "id": "profile_performance",
          "name": "Profile service latency p50/p95/p99",
          "node": "HeadyHealth",
          "action": "profile",
          "params": {
            "windowMinutes": 55
          }
        },
        {
          "id": "detect_waste",
          "name": "Detect dead code, unused services, cost waste",
          "node": "HeadyDeepScan",
          "action": "detectWaste",
          "params": {
            "methods": [
              "ast_reachability",
              "traffic_analysis",
              "cost_per_request"
            ]
          }
        },
        {
          "id": "rank_optimizations",
          "name": "Rank optimization opportunities by CSL impact score",
          "node": "HeadyConductor",
          "action": "rankOptimizations",
          "params": {
            "costWeight": 0.382,
            "perfWeight": 0.382,
            "reliabilityWeight": 0.236
          }
        }
      ]
    },
    {
      "id": "stage_continuous_search",
      "name": "Continuous Search & Discovery",
      "order": 7.3,
      "required": false,
      "timeout": 29034,
      "parallel": true,
      "steps": [
        {
          "id": "search_innovations",
          "name": "Search for new tools, research, and patterns",
          "node": "HeadyPerplexity",
          "action": "search",
          "params": {
            "categories": [
              "npm",
              "arxiv",
              "github",
              "security"
            ],
            "maxResults": 8
          }
        },
        {
          "id": "evaluate_discoveries",
          "name": "CSL-score relevance and applicability",
          "node": "HeadySoul",
          "action": "evaluate",
          "params": {
            "threshold": 0.618
          }
        },
        {
          "id": "absorb_findings",
          "name": "Embed high-value findings into knowledge",
          "node": "HeadyMemory",
          "action": "store",
          "params": {
            "namespace": "discoveries"
          }
        }
      ]
    },
    {
      "id": "stage_evolution",
      "name": "Evolution & Mutation",
      "order": 7.7,
      "required": false,
      "timeout": 29034,
      "parallel": false,
      "enabledWhen": "pipeline.evolutionEnabled === true",
      "steps": [
        {
          "id": "generate_mutations",
          "name": "Generate controlled parameter mutations",
          "node": "HeadyBrains",
          "action": "mutate",
          "params": {
            "rate": 0.0618,
            "populationSize": 8,
            "maxMagnitude": 0.13
          }
        },
        {
          "id": "simulate_mutations",
          "name": "Simulate mutations via HeadySims",
          "node": "HeadyConductor",
          "action": "monteCarlo",
          "params": {
            "iterations": 500,
            "compareToBaseline": true
          }
        },
        {
          "id": "promote_winners",
          "name": "Promote beneficial mutations to config",
          "node": "HeadyGovernance",
          "action": "promoteIfBeneficial",
          "params": {
            "rollbackThreshold": 0.05,
            "approvalThreshold": 0.08
          }
        },
        {
          "id": "record_evolution",
          "name": "Record evolution history",
          "node": "HeadyAutobiographer",
          "action": "record",
          "params": {
            "events": [
              "mutation_generated",
              "mutation_tested",
              "mutation_promoted",
              "mutation_discarded"
            ]
          }
        }
      ]
    }
  ],
  "pools": {
    "llm_tokens": {
      "description": "LLM token budget per pipeline run",
      "default": 50000,
      "max": 200000,
      "warningThreshold": 40000,
      "byStage": {
        "stage_intake": 2000,
        "stage_recon": 3000,
        "stage_memory": 3000,
        "stage_routing": 3000,
        "stage_trial_and_error": 8000,
        "stage_execution": 30000,
        "stage_self_awareness": 5000,
        "stage_evaluation": 10000,
        "stage_mistake_analysis": 3000,
        "stage_optimization_ops": 3000,
        "stage_learning": 5000,
        "stage_continuous_search": 5000,
        "stage_evolution": 8000
      }
    },
    "concurrent_requests": {
      "description": "Max concurrent LLM/API requests",
      "default": 5,
      "max": 20,
      "perNode": {
        "HeadySoul": 3,
        "HeadyBrains": 2,
        "HeadyVinci": 5,
        "HeadyArena": 4,
        "HeadyBee": 10
      }
    },
    "bee_workers": {
      "description": "Max bee worker agents per pipeline run",
      "default": 3,
      "max": 10,
      "ttl": 300
    },
    "cost_usd": {
      "description": "Max cost per pipeline run in USD",
      "default": 1.00,
      "max": 10.00,
      "fullAutoMax": 5.00,
      "trackingEnabled": true
    }
  },
  "timeouts": {
    "total_pipeline": 300000,
    "per_stage_default": 30000,
    "per_step_default": 15000,
    "llm_call": 60000,
    "embedding": 10000,
    "db_query": 5000,
    "governance_check": 5000,
    "bee_spawn": 10000,
    "bee_task": 120000,
    "recon_scan": 6854,
    "trial_sandbox": 17944,
    "self_awareness": 11090,
    "mistake_analysis": 11090,
    "optimization_ops": 17944,
    "continuous_search": 29034,
    "evolution_simulation": 29034
  },
  "errorHandling": {
    "onStageFailure": "skip_optional_continue_required",
    "onStepFailure": "retry_then_skip",
    "onGovernanceDeny": "halt_immediately",
    "onBudgetExceeded": "halt_and_alert",
    "alertChannels": [
      "story_driver",
      "log",
      "webhook"
    ],
    "webhookUrl": "${ALERT_WEBHOOK_URL}"
  },
  "hooks": {
    "onPipelineStart": [
      "story_driver.record",
      "budget.checkpoint"
    ],
    "onStageStart": [
      "budget.checkpoint"
    ],
    "onStageComplete": [
      "story_driver.record"
    ],
    "onPipelineComplete": [
      "story_driver.record",
      "budget.finalize",
      "coherence.update"
    ],
    "onPipelineError": [
      "story_driver.record",
      "budget.finalize",
      "alert.send"
    ]
  }
}