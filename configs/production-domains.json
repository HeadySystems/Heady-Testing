{
  "domains": [
    {
      "domain": "headyme.com",
      "type": "cloudflare-pages",
      "site": "headyme",
      "backendProxy": "https://manager.headysystems.com"
    },
    {
      "domain": "www.headyme.com",
      "redirect": "headyme.com"
    },
    {
      "domain": "headysystems.com",
      "type": "cloudflare-pages",
      "site": "headysystems",
      "backendProxy": "https://manager.headysystems.com"
    },
    {
      "domain": "www.headysystems.com",
      "redirect": "headysystems.com"
    },
    {
      "domain": "manager.headysystems.com",
      "type": "cloud-run",
      "service": "heady-manager"
    },
    {
      "domain": "api.headysystems.com",
      "type": "cloudflare-worker",
      "worker": "liquid-gateway-worker",
      "backendService": "api-gateway"
    },
    {
      "domain": "api-internal.headysystems.com",
      "type": "cloud-run",
      "service": "api-gateway",
      "internal": true
    },
    {
      "domain": "headybuddy.org",
      "type": "cloudflare-pages",
      "site": "headybuddy",
      "backendProxy": "https://manager.headysystems.com"
    },
    {
      "domain": "www.headybuddy.org",
      "redirect": "headybuddy.org"
    },
    {
      "domain": "headymcp.com",
      "type": "cloudflare-pages",
      "site": "headymcp",
      "backendProxy": "https://manager.headysystems.com"
    },
    {
      "domain": "www.headymcp.com",
      "redirect": "headymcp.com"
    },
    {
      "domain": "headyio.com",
      "type": "cloudflare-pages",
      "site": "headyio",
      "backendProxy": "https://manager.headysystems.com"
    },
    {
      "domain": "www.headyio.com",
      "redirect": "headyio.com"
    },
    {
      "domain": "headyio.com/mcp",
      "type": "mcp-endpoint",
      "worker": "heady-mcp-worker"
    },
    {
      "domain": "headyconnection.org",
      "type": "cloudflare-pages",
      "site": "headyconnection",
      "backendProxy": "https://manager.headysystems.com"
    },
    {
      "domain": "www.headyconnection.org",
      "redirect": "headyconnection.org"
    },
    {
      "domain": "headyapi.com",
      "type": "cloudflare-pages",
      "site": "headyapi",
      "backendProxy": "https://manager.headysystems.com"
    },
    {
      "domain": "headyos.com",
      "type": "cloudflare-pages",
      "site": "headyos",
      "backendProxy": "https://manager.headysystems.com"
    },
    {
      "domain": "auth.headysystems.com",
      "type": "cloudflare-worker",
      "worker": "edge-auth-worker"
    },
    {
      "domain": "buddy-sync.headysystems.com",
      "type": "cloud-run",
      "service": "heady-buddy",
      "websocket": true
    },
    {
      "domain": "pipeline.headysystems.com",
      "type": "cloud-run",
      "service": "hcfullpipeline-executor"
    },
    {
      "domain": "telemetry.headysystems.com",
      "type": "cloudflare-worker",
      "worker": "worker-mcp-telemetry"
    }
  ]
}