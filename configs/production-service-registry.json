      "routes": [
        "*/ai/*"
      ]
    },
    "worker-heady-router": {
      "domain": "router.headysystems.com",
      "routes": [
        "*/*"
      ]
    },
    "worker-mcp-telemetry": {
      "domain": "telemetry.headysystems.com",
      "routes": [
        "*/telemetry/*"
      ]
    }
