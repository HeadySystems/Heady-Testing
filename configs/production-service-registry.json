  "workers": {
    "edge-auth-worker": {
      "domain": "auth.headysystems.com",
      "routes": [
        "*/api/auth/*"
      ]
    },
    "heady-mcp-worker": {
      "domain": "mcp.headysystems.com",
      "routes": [
        "*/mcp/*"
      ]
    },
    "liquid-gateway-worker": {
      "domain": "gateway.headysystems.com",
      "routes": [
        "*/api/*"
      ]
    },
    "heady-buddy-worker": {
