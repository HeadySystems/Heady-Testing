    "discord-bot": {
      "port": 4329,
      "healthPath": "/health",
      "role": "discord"
    },
    "hcfullpipeline-executor": {
      "port": 4330,
      "healthPath": "/health",
      "role": "pipeline"
    }
  },
  "workers": {
    "edge-auth-worker": {
      "domain": "auth.headysystems.com",
      "routes": [
        "*/api/auth/*"
      ]
    },
    "heady-mcp-worker": {
      "domain": "mcp.headysystems.com",
      "routes": [
        "*/mcp/*"
      ]
    },
    "liquid-gateway-worker": {
      "domain": "gateway.headysystems.com",
      "routes": [
        "*/api/*"
      ]
    },
    "heady-buddy-worker": {
      "domain": "buddy.headysystems.com",
      "routes": [
        "*/buddy/*"
      ]
    },
    "edge-composer": {
      "domain": "compose.headysystems.com",
      "routes": [
        "*/compose/*"
      ]
    },
    "worker-ai-gateway": {
      "domain": "ai.headysystems.com",
      "routes": [
        "*/ai/*"
      ]
    },
    "worker-heady-router": {
      "domain": "router.headysystems.com",
      "routes": [
        "*/*"
      ]
    },
    "worker-mcp-telemetry": {
      "domain": "telemetry.headysystems.com",
      "routes": [
        "*/telemetry/*"
      ]
    }
  },
  "infrastructure": {
    "postgres": {
      "port": 5432,
      "extensions": [
        "pgvector",
        "pg_trgm"
      ],
      "version": "16"
    },
    "redis": {
      "port": 6379,
      "maxMemory": "256mb",
      "version": "7"
    },
    "pgbouncer": {
      "port": 6432
    },
    "otel-collector": {
      "grpcPort": 4317,
      "httpPort": 4318,
      "metricsPort": 8889
    }
  },
  "sitePortMap": {
    "headyme": 9001,
    "headyme-com": 9002,
