{
  "version": "4.0.0",
  "environment": "production",
  "domains": {
    "headyme.com": {
      "site": "headyme",
      "port": 9001,
      "cloudrunService": "headyme-web",
      "cloudflareZone": "CF_ZONE_HEADYME"
    },
    "headysystems.com": {
      "site": "headysystems",
      "port": 9002,
      "cloudrunService": "headysystems-web",
      "cloudflareZone": "CF_ZONE_HEADYSYSTEMS"
    },
    "headybuddy.org": {
      "site": "headybuddy",
      "port": 9003,
      "cloudrunService": "headybuddy-web",
      "cloudflareZone": "CF_ZONE_HEADYBUDDY"
    },
    "headymcp.com": {
      "site": "headymcp",
      "port": 9004,
      "cloudrunService": "headymcp-web",
      "cloudflareZone": "CF_ZONE_HEADYMCP"
    },
    "headyio.com": {
      "site": "headyio",
      "port": 9005,
      "cloudrunService": "headyio-web",
      "cloudflareZone": "CF_ZONE_HEADYIO"
