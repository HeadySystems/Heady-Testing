# HEADY PRE-PUSH HOOK — Automatic syntax validation before push
# Prevents broken code from reaching remote.

echo "═══ Heady Pre-Push Check ═══"

# Check heady-manager.js syntax
if [ -f "heady-manager.js" ]; then
  node --check heady-manager.js 2>&1
  if [ $? -ne 0 ]; then
    echo "❌ heady-manager.js has syntax errors — push blocked"
    exit 1
  fi
  echo "✅ heady-manager.js syntax OK"
fi

# Check all services
for f in services/*.js; do
  if [ -f "$f" ]; then
