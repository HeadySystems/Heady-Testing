#!/bin/bash
# Heady Pre-Commit Hook — S-9 Enhancement
# Scans for secrets locally before commits reach remote

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'
VIOLATIONS=0

echo "🔒 Heady Pre-Commit Secret Scan..."

# Check for .env files being committed
ENV_FILES=$(git diff --cached --name-only | grep -E '\.env($|\.local|\.production|\.hybrid)' | grep -v '\.example' | grep -v '\.template')
if [ -n "$ENV_FILES" ]; then
  echo -e "${RED}❌ BLOCKED: .env file(s) staged for commit:${NC}"
  echo "$ENV_FILES"
  VIOLATIONS=$((VIOLATIONS + 1))
fi

# Check for private keys
KEY_FILES=$(git diff --cached --name-only | grep -E '\.(pem|key|p12|pfx)$')
if [ -n "$KEY_FILES" ]; then
  echo -e "${RED}❌ BLOCKED: Private key file(s) staged:${NC}"
  echo "$KEY_FILES"
  VIOLATIONS=$((VIOLATIONS + 1))
fi

# Check for hardcoded API keys in staged files
STAGED_CONTENT=$(git diff --cached -U0 | grep -E '^\+' | grep -v '^\+\+\+')
if echo "$STAGED_CONTENT" | grep -qE 'sk-[a-zA-Z0-9]{20,}'; then
  echo -e "${RED}❌ BLOCKED: Potential API key (sk-*) in staged changes${NC}"
  VIOLATIONS=$((VIOLATIONS + 1))
fi

if echo "$STAGED_CONTENT" | grep -qE 'AKIA[0-9A-Z]{16}'; then
  echo -e "${RED}❌ BLOCKED: AWS access key (AKIA*) in staged changes${NC}"
  VIOLATIONS=$((VIOLATIONS + 1))
fi

if echo "$STAGED_CONTENT" | grep -qE -- '-----BEGIN (RSA |EC )?PRIVATE KEY-----'; then
  echo -e "${RED}❌ BLOCKED: Private key block in staged changes${NC}"
  VIOLATIONS=$((VIOLATIONS + 1))
fi

# Check for .pid, .bak, .jsonl files
BAD_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(pid|bak|jsonl)$')
if [ -n "$BAD_FILES" ]; then
  echo -e "${RED}❌ BLOCKED: Forbidden file type(s) staged:${NC}"
  echo "$BAD_FILES"
  VIOLATIONS=$((VIOLATIONS + 1))
fi

if [ $VIOLATIONS -gt 0 ]; then
  echo -e "\n${RED}🚫 $VIOLATIONS violation(s) found. Commit blocked.${NC}"
  echo "Fix the issues above and try again."
  exit 1
fi

echo -e "${GREEN}✅ Pre-commit secret scan passed${NC}"
exit 0
