{
    "manifest_version": 3,
    "name": "Heady AI — Brain in Every Tab",
    "short_name": "Heady",
    "version": "2.0.0",
    "description": "AI assistant powered by the Heady Intelligence Layer. Chat, code, analyze, and create from any webpage. 9 service groups, 20 AI nodes.",
    "permissions": [
        "activeTab",
        "contextMenus",
        "storage",
        "sidePanel",
        "tabs"
    ],
    "host_permissions": [
        "https://headyme.com/*",
        "https://manager.headysystems.com/*",
        "https://api.headysystems.com/*",
        "https://*.headysystems.com/*",
        "https://*.headyme.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/heady-16.png",
            "48": "icons/heady-48.png",
            "128": "icons/heady-128.png"
        }
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "options_page": "options.html",
    "icons": {
        "16": "icons/heady-16.png",
        "48": "icons/heady-48.png",
        "128": "icons/heady-128.png"
    },
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+H",
                "mac": "Command+Shift+H"
            },
            "description": "Open Heady"
        }
    }
}