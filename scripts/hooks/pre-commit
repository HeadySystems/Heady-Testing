#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════════╗
# ║  HEADY™ Pre-Commit Hook v1.0.0                                 ║
# ║  Patent-Lock Enforcement + Secret Hygiene Guard                ║
# ║  © 2026 HeadySystems Inc. — Eric Haywood, Founder              ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# Enforces two policies before every commit:
#   1. PATENT LOCK  — blocks edits to files containing PATENT LOCK markers
#                     or patent IDs HS-2026-051 through HS-2026-062 unless
#                     an ARBITER swarm review token is present.
#   2. SECRET GUARD — blocks commits of known sensitive file patterns
#                     (env.local, env.production, *.exe, hc_pipeline.log, etc.)
#
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Skip (emergency only): SKIP_PATENT_LOCK=1 git commit -m "..."

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

ARBITER_TOKEN_FILE=".heady/arbiter-token"
ERRORS=0

echo ""
echo "🛡️  Heady Pre-Commit: Patent Lock + Secret Guard"
echo "────────────────────────────────────────────────"

# ─── 1. SECRET GUARD ──────────────────────────────────────────────────────────
BLOCKED_FILES=(
  "env.local"
  "env.production"
  ".env.local"
  ".env.production"
  "hc_pipeline.log"
  "cloudflared.exe"
)

BLOCKED_PATTERNS=(
  "*.exe"
  "*.pem"
  "*.key"
  "*.p12"
  "*-service-account*.json"
  "gcp-*.json"
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

for blocked in "${BLOCKED_FILES[@]}"; do
  if echo "$STAGED_FILES" | grep -qF "$blocked"; then
    echo -e "${RED}✖ SECRET GUARD: '$blocked' must not be committed.${NC}"
    echo "  Run: git rm --cached $blocked"
    ERRORS=$((ERRORS + 1))
  fi
done

for pattern in "${BLOCKED_PATTERNS[@]}"; do
  matches=$(echo "$STAGED_FILES" | grep -E "$(echo "$pattern" | sed 's/\*/.*/g')" || true)
  if [ -n "$matches" ]; then
    echo -e "${RED}✖ SECRET GUARD: Blocked pattern '$pattern' matched:${NC}"
    echo "$matches" | sed 's/^/    /'
    ERRORS=$((ERRORS + 1))
  fi
done

# ─── 2. PATENT LOCK ───────────────────────────────────────────────────────────
if [ "${SKIP_PATENT_LOCK:-0}" = "1" ]; then
  echo -e "${YELLOW}⚠ PATENT LOCK bypassed via SKIP_PATENT_LOCK=1 — logged.${NC}"
  echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) BYPASS by $(git config user.email) files: $STAGED_FILES" \
    >> data/patent-lock-bypass.log 2>/dev/null || true
else
  PATENT_PATTERN='(PATENT[[:space:]]*LOCK|HS-2026-05[1-9]|HS-2026-06[0-2])'

  for file in $STAGED_FILES; do
    [ -f "$file" ] || continue

    # Check filename contains patent ID
    if echo "$file" | grep -qE "$PATENT_PATTERN"; then
      PATENT_LOCKED=1
    # Check file content (first 200 lines for speed)
    elif head -n 200 "$file" 2>/dev/null | grep -qE "$PATENT_PATTERN"; then
      PATENT_LOCKED=1
    else
      PATENT_LOCKED=0
    fi

    if [ "$PATENT_LOCKED" = "1" ]; then
      # Check for valid ARBITER swarm token
      if [ -f "$ARBITER_TOKEN_FILE" ]; then
        TOKEN=$(cat "$ARBITER_TOKEN_FILE" 2>/dev/null || true)
        # Token must be non-empty and issued within the last 24 hours
        TOKEN_TS=$(echo "$TOKEN" | grep -oE '[0-9]{10}' | head -1 || echo "0")
        NOW_TS=$(date +%s)
        AGE=$((NOW_TS - TOKEN_TS))
        if [ "$AGE" -gt 86400 ]; then
          echo -e "${RED}✖ PATENT LOCK: '$file' — ARBITER token expired (age: ${AGE}s).${NC}"
          echo "  Obtain a fresh token from the ARBITER swarm and place in $ARBITER_TOKEN_FILE"
          ERRORS=$((ERRORS + 1))
        else
          echo -e "${GREEN}✔ PATENT LOCK: '$file' — ARBITER token valid (age: ${AGE}s).${NC}"
        fi
      else
        echo -e "${RED}✖ PATENT LOCK: '$file' is in a patent-locked zone.${NC}"
        echo "  Patent IDs: HS-2026-051 … HS-2026-062"
        echo "  ARBITER swarm review required. Place token in: $ARBITER_TOKEN_FILE"
        echo "  Or bypass (emergency only): SKIP_PATENT_LOCK=1 git commit ..."
        ERRORS=$((ERRORS + 1))
      fi
    fi
  done
fi

# ─── Result ───────────────────────────────────────────────────────────────────
echo "────────────────────────────────────────────────"
if [ "$ERRORS" -gt 0 ]; then
  echo -e "${RED}✖ Pre-commit blocked: $ERRORS issue(s) found.${NC}"
  echo ""
  exit 1
else
  echo -e "${GREEN}✔ Pre-commit checks passed.${NC}"
  echo ""
  exit 0
fi
