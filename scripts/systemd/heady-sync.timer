[Unit]
Description=Heady Cross-Device Git Sync Timer
Documentation=https://github.com/HeadyAI/Heady

[Timer]
# Run every 10 minutes
OnBootSec=2min
OnUnitActiveSec=10min

# Add some randomness to avoid exact collision with other device timers
RandomizedDelaySec=30

# Persist timer across reboots
Persistent=true

[Install]
WantedBy=timers.target
