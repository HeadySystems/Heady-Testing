{
  "name": "headybuddy-desktop",
  "version": "3.1.0",
  "description": "HeadyBuddy Desktop — AI Companion with Task Automation for Windows, Linux, macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:widget": "cd ../headybuddy && npm run build",
    "package": "npm run build:widget && electron-builder --publish never",
    "package:win": "npm run build:widget && electron-builder --win",
    "package:linux": "npm run build:widget && electron-builder --linux",
    "package:mac": "npm run build:widget && electron-builder --mac",
    "package:all": "npm run build:widget && electron-builder -mwl"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.headysystems.headybuddy",
    "productName": "HeadyBuddy",
    "artifactName": "HeadyBuddy-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "tray.js",
      "icons/**/*"
    ],
    "extraResources": [
      {
        "from": "../headybuddy/dist",
        "to": "widget",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "arm64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "icons/icon.ico",
      "publisherName": "HeadySystems Inc."
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HeadyBuddy",
      "runAfterFinish": true
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "deb", "arch": ["x64"] },
        { "target": "snap", "arch": ["x64"] }
      ],
      "icon": "icons/icon.png",
      "category": "Utility",
      "maintainer": "eric@headyconnection.org",
      "synopsis": "HeadyBuddy AI Companion",
      "description": "HeadyBuddy — Your Perfect AI Companion. Task automation, smart assistance, and cloud-powered intelligence.",
      "desktop": {
        "Name": "HeadyBuddy",
        "Comment": "AI Companion by HeadySystems",
        "Keywords": "AI;Assistant;Companion;Automation;HeadySystems",
        "StartupWMClass": "headybuddy-desktop"
      }
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "icons/icon.icns",
      "category": "public.app-category.productivity"
    },
    "publish": {
      "provider": "github",
      "owner": "HeadyMe",
      "repo": "headybuddy-desktop"
    }
  }
}
