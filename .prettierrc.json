{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "overrides": [
    {
      "files": "*.json",
      "options": {
        "printWidth": 89
      }
    },
    {
      "files": "*.md",
      "options": {
        "printWidth": 144,
        "proseWrap": "always"
      }
    }
  ]
}
