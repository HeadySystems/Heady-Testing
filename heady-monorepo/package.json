    "node-fetch": "^3.3.2",
    "js-yaml": "^4.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "stripe": "^17.5.0",
    "express-rate-limit": "^7.5.0",
    "morgan": "^1.10.0",
    "body-parser": "^1.20.3",
