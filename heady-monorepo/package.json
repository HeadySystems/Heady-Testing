    "express-validator": "^7.2.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-github2": "^0.1.12",
    "passport-local": "^1.0.0",
    "jsonlines": "^0.1.1",
    "hash.js": "^1.1.7",
    "elliptic": "^6.6.1",
    "crypto-js": "^4.2.0",
