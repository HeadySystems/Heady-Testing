{
  "name": "heady-systems",
  "version": "3.1.0",
  "description": "Heady™ AI Platform — Autonomous multi-agent AI operating system with 20 specialized intelligence nodes, federated liquid routing, and post-quantum security.",
  "main": "heady-manager.js",
  "license": "UNLICENSED",
  "private": true,
  "author": {
    "name": "HeadyMe",
    "email": "eric@headyconnection.org",
    "url": "https://headyme.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HeadyMe/Heady-pre-production-9f2f0642.git"
  },
  "homepage": "https://headysystems.com",
  "bugs": {
    "url": "https://github.com/HeadyMe/Heady-pre-production-9f2f0642/issues",
    "email": "eric@headyconnection.org"
  },
  "keywords": [
    "ai", "multi-agent", "mcp", "post-quantum", "arena-mode",
    "headybrain", "headyswarm", "liquid-routing", "sacred-geometry",
    "vector-memory", "pgvector", "circuit-breaker"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node heady-manager.js",
    "start:mcp": "node heady-manager.js --mcp",
    "dev": "nodemon heady-manager.js",
    "build": "node scripts/generate-sites.js && echo 'Build complete'",
    "test": "jest",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "health": "curl -s http://localhost:3301/health/live",
    "status": "pm2 list",
    "manager:restart": "pm2 restart heady-manager",
    "healthcheck": "node scripts/healthcheck.js",
    "db:migrate": "node scripts/db-migrate.js",
    "db:seed": "node scripts/db-seed.js",
    "pipeline": "node -e \"const {pipeline}=require('./src/hcfp/pipeline-runner');pipeline.run().then(s=>console.log(JSON.stringify(s,null,2))).catch(e=>console.error(e.message))\"",
    "buddy:status": "node -e \"const {BuddySystem}=require('./src/services/buddy-system');const b=new BuddySystem();console.log(JSON.stringify(b.status(),null,2))\"",
    "deploy": "node scripts/deploy.js",
    "deploy:auto": "node scripts/deploy.js --auto",
    "branch:sync": "node scripts/branch-sync.js",
    "vector:project": "node scripts/autonomous/vector-projection-orchestrator.js",
    "vector:autopilot": "node scripts/autonomous/vector-projection-orchestrator.js --watch",
    "battle": "node scripts/battle.js",
    "battle:status": "node scripts/battle.js --status"
  },
