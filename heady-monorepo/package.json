    "node-cron": "^3.0.3",
    "duckdb": "^1.1.4",
    "better-sqlite3": "^11.7.0",
    "yaml": "^2.7.0",
    "minimatch": "^10.0.1",
    "glob": "^11.0.1",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "@anthropic-ai/sdk": "^0.36.3",
