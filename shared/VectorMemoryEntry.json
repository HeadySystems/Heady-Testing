{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.headysystems.com/schemas/VectorMemoryEntry",
  "type": "object",
  "required": [
    "content",
    "embedding",
    "domain"
  ],
  "properties": {
    "content": {
      "type": "string",
      "maxLength": 6765
    },
    "embedding": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 384,
      "maxItems": 384
    },
    "domain": {
      "type": "string",
      "maxLength": 89
    },
    "metadata": {
      "type": "object"
    },
    "importance": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 0.618
    }
  }
}