{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.headysystems.com/inference-request.json",
  "title": "Inference Request",
  "type": "object",
  "required": [
    "prompt"
  ],
  "properties": {
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string"
    },
    "temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2,
      "default": 0
    },
    "seed": {
      "type": "integer",
      "default": 42
    },
    "maxTokens": {
      "type": "integer",
      "minimum": 1,
      "maximum": 377
    },
    "stream": {
      "type": "boolean",
      "default": false
    },
    "systemPrompt": {
      "type": "string"
    }
  }
}