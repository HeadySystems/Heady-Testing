{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://headysystems.com/schemas/health-response.json",
  "title": "Heady™ Health Response",
  "description": "Standard health check response for all 58 Heady™ platform services. All services are concurrent equals.",
  "type": "object",
  "required": ["service", "status", "domain", "uptime", "port", "vectorDim", "circuitBreaker", "timestamp"],
  "properties": {
    "service": {
      "type": "string",
      "description": "Service name identifier",
      "examples": ["heady-brain", "auth-session-server", "search-service"]
    },
    "status": {
      "type": "string",
      "enum": ["operational", "degraded", "unavailable"],
      "description": "Current service operational status"
    },
    "domain": {
      "type": "string",
      "enum": ["intelligence", "agents", "security", "monitoring", "user-facing", "pipeline", "routing", "integration", "specialized", "data", "orchestration", "web"],
      "description": "Service domain classification"
    },
    "uptime": {
      "type": "integer",
      "minimum": 0,
      "description": "Uptime in seconds since service boot"
    },
    "port": {
      "type": "integer",
      "minimum": 3310,
      "maximum": 3404,
      "description": "Service port number"
    },
    "vectorDim": {
      "type": "integer",
      "const": 384,
      "description": "Vector dimension constant (VECTOR_DIM)"
    },
    "phiVersion": {
      "type": "string",
      "description": "Golden ratio constant value (15 decimal places)",
      "pattern": "^1\\.618033988749895$"
    },
    "circuitBreaker": {
      "type": "string",
      "enum": ["closed", "open", "half-open"],
      "description": "Fibonacci-based circuit breaker state"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of health check"
    }
  },
  "additionalProperties": true
}
