{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.headysystems.com/health-response.json",
  "title": "Health Check Response",
  "description": "Standard health response for all 50 Heady services",
  "type": "object",
  "required": [
    "status",
    "service",
    "uptime",
    "timestamp"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "healthy",
        "degraded",
        "unhealthy"
      ]
    },
    "service": {
      "type": "string",
      "minLength": 1
    },
    "uptime": {
      "type": "number",
      "minimum": 0
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "warn",
              "fail"
            ]
          },
          "latencyMs": {
            "type": "number"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}